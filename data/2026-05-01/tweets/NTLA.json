 [{"h": 420, "w": 750, "x": 0, "y": 0}, {"h": 750, "w": 750, "x": 0, "y": 0}, {"h": 855, "w": 750, "x": 0, "y": 0}, {"h": 1334, "w": 667, "x": 0, "y": 0}, {"h": 1334, "w": 750, "x": 0, "y": 0}], "height": 1334, "width": 750}, "sizes": {"large": {"h": 1334, "w": 750}}, "type": "photo", "url": "https://t.co/OS2XGdDNPm"}, {"allow_download_status": {"allow_download": true}, "display_url": "pic.twitter.com/OS2XGdDNPm", "expanded_url": "https://twitter.com/GeneInvesting/status/2049847708333248955/photo/1", "ext_media_availability": {"status": "Available"}, "features": {"large": {"faces": []}, "orig": {"faces": []}}, "id_str": "2049847703207813120", "indices": [280, 303], "media_key": "3_2049847703207813120", "media_results": {"id": "QXBpTWVkaWFSZXN1bHRzOgwAAQoAARxyhaAhWiAACgACHHKFoVLaEbsAAA==", "result": {"__typename": "ApiMedia", "id": "QXBpTWVkaWE6DAABCgABHHKFoCFaIAAKAAIccoWhUtoRuwAA", "media_key": "3_2049847703207813120"}}, "media_url_https": "https://pbs.twimg.com/media/HHKFoCFaIAAwsD5.jpg", "original_info": {"focus_rects": [{"h": 420, "w": 750, "x": 0, "y": 0}, {"h": 750, "w": 750, "x": 0, "y": 0}, {"h": 855, "w": 750, "x": 0, "y": 0}, {"h": 1334, "w": 667, "x": 42, "y": 0}, {"h": 1334, "w": 750, "x": 0, "y": 0}], "height": 1334, "width": 750}, "sizes": {"large": {"h": 1334, "w": 750}}, "type": "photo", "url": "https://t.co/OS2XGdDNPm"}]}, "card": null, "place": {}, "entities": {"hashtags": [], "symbols": [{"indices": [66, 71], "text": "NTLA"}], "urls": [], "user_mentions": []}, "quoted_tweet": null, "retweeted_tweet": null, "isLimitedReply": false, "communityInfo": null, "article": null}, {"type": "tweet", "id": "2049879287352963415", "url": "https://x.com/GeneInvesting/status/2049879287352963415", "twitterUrl": "https://twitter.com/GeneInvesting/status/2049879287352963415", "text": "A thread \ud83e\uddf5 \n\nSO YOU\u2019RE CONFUSED ABOUT $NTLA? \n\nLook below for #1-10 \ud83d\udc40 \u2b07\ufe0f \n\n1\ufe0f\u20e3 Never compare Lonvo-z to hemophilia \n\u2022 hemophilia drugs have had durability/waning effects\n\u2022 no payer wants to pay millions for something that has waning efficacy \n\u2022 AAV delivery comes with safety concerns and extra complexity pre-dose\n\n2\ufe0f\u20e3 Never compare Lonvo-z to Casgevy \n\u2022 patients can die from chemo \n\u2022 7-9 month treatment process \n\u2022 transplant \n\u2022 Lonvo-z is outpatient 2-4 hour drip \ud83d\udca7 \n\n3\ufe0f\u20e3 Lonvo-z (HAE) has had zero Grade 3/4 liver elevations \n\u2022 bears constantly lie about this\n\n4\ufe0f\u20e3 ATTR CM resumed enrollment on 3/27 and ATTR PN on 4/16\n\u2022 bears continue lying a month later saying both trials have yet to resume enrollment\n\u2022 holds were lifted extremely fast (3 & 4 months)\n\n5\ufe0f\u20e3 Not understanding HAE trial dynamics\n\u2022 when blinded patients unaware if they received actual drug will often self medicate with on demand medication if they have any itch, sore throat, cramps etc. These count as attacks and make bears look extremely idiotic.\n\u2022 once unblinded 31/32 in Ph. 1/2 appeared potentially cured\n\n6\ufe0f\u20e3 2\u201d duodenal ulcers \n\u2022 this is an extra large ulcer- double the size of a giant ulcer \n\u2022 these don\u2019t magically appear\n\u2022 patient must\u2019ve had this prior to dosing and steroids given in hospital likely perforated it\n\n7\ufe0f\u20e3 Difference between chronic liver elevations and one and done\n\u2022 Hy\u2019s law can be a death sentence for traditional (chronic) medicines.\n\u2022 Nex-z has a known ~2 week window where this phenomenon is contained in\n\u2022 chronically dosed can\u2019t be mitigated since it could appear at any moment \n\n8\ufe0f\u20e3 Physician survey for HAE\n\u2022 bears say don\u2019t pay attention to surveys\n\u2022 Intellia covered physicians who oversee 4000+/7000 US patients. \n\u2022 Hard to ignore that survey size\n\u2022 92% of doctors would prescribe \n\u2022 54% of patients would receive prescription \n\n9\ufe0f\u20e3 HAE cost of current therapies \n\u2022 commonly and hilariously misrepresented by bears\n\u2022 $500-$600k+ for leading prophylactics\n\u2022 Lonvo will likely be $2m+ but under $3m\n\n\ud83d\udd1f Patient need in HAE \n\u2022 more than half still struggle with breakthrough attacks etc\n\u2022 ~80% still have at least some attacks\n\u2022 one attack is too many because a throat swell can be deadly\n\u2022 better options continue coming out yet above all patients want to be cured", "source": "Twitter for iPhone", "retweetCount": 4, "replyCount": 2, "likeCount": 22, "quoteCount": 0, "viewCount": 1622, "createdAt": "Thu Apr 30 15:51:21 +0000 2026", "lang": "en", "bookmarkCount": 5, "isReply": false, "inReplyToId": null, "conversationId": "2049879287352963415", "displayTextRange": [0, 275], "inReplyToUserId": null, "inReplyToUsername": null, "author": {"type": "user", "userName": "GeneInvesting", "url": "https://x.com/GeneInvesting", "twitterUrl": "https://twitter.com/GeneInvesting", "id": "1246632233579896833", "name": "Gene Investing w/Anthony \ud83e\uddec", "isVerified": false, "isBlueVerified": true, "verifiedType": null, "profilePicture": "https://pbs.twimg.com/profile_images/1483585437482373121/o2DEo51j_normal.jpg", "coverPicture": "https://pbs.twimg.com/profile_banners/1246632233579896833/1645233705", "description": "", "location": "California, USA", "followers": 15459, "following": 486, "status": "", "canDm": true, "canMediaTag": true, "createdAt": "Sun Apr 05 02:54:34 +0000 2020", "entities": {"description": {"urls": []}, "url": {}}, "fastFollowersCount": 0, "favouritesCount": 80867, "hasCustomTimelines": true, "isTranslator": false, "mediaCount": 6248, "statusesCount": 69435, "withheldInCountries": [], "affiliatesHighlightedLabel": {}, "possiblySensitive": false, "pinnedTweetIds": ["1696875919749820684"], "profile_bio": {"description": "Your source for the latest #Science and #Biotech news. If you're interested in #CRISPR #GeneEditing hit follow! Spaces podcast host\u