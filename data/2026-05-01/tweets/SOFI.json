g": true, "createdAt": "Tue Jun 25 12:53:52 +0000 2024", "entities": {"description": {"urls": []}, "url": {}}, "fastFollowersCount": 0, "favouritesCount": 13871, "hasCustomTimelines": true, "isTranslator": false, "mediaCount": 476, "statusesCount": 12657, "withheldInCountries": [], "affiliatesHighlightedLabel": {}, "possiblySensitive": false, "pinnedTweetIds": [], "profile_bio": {"description": "Market narratives \u2022 US equities \u2022 Macro insights \u2022 Thinking out loud like an investor, not a commentator || NFA", "entities": {"description": {}, "url": {"urls": [{"display_url": "t.me/UnotheInvestor", "expanded_url": "https://t.me/UnotheInvestor", "indices": [0, 23], "url": "https://t.co/Tn0AGnKc9p"}]}}}, "isAutomated": false, "automatedBy": null}, "extendedEntities": {"media": [{"additional_media_info": {"monetizable": true}, "allow_download_status": {"allow_download": false}, "display_url": "pic.twitter.com/LF0ljxws0Q", "expanded_url": "https://twitter.com/UnotheInvestor/status/2050154697168667129/video/1", "ext_media_availability": {"status": "Available"}, "id_str": "2050154275020410880", "indices": [221, 244], "media_key": "13_2050154275020410880", "media_results": {"id": "QXBpTWVkaWFSZXN1bHRzOgwABAoAARxznHNxVxAAAAA=", "result": {"__typename": "ApiMedia", "id": "QXBpTWVkaWE6DAAECgABHHOcc3FXEAAAAA==", "media_key": "13_2050154275020410880"}}, "media_url_https": "https://pbs.twimg.com/amplify_video_thumb/2050154275020410880/img/v-Q_-cYL9cn9pNsz.jpg", "original_info": {"focus_rects": [], "height": 452, "width": 886}, "sizes": {"large": {"h": 452, "w": 886}}, "type": "video", "url": "https://t.co/LF0ljxws0Q", "video_info": {"aspect_ratio": [443, 226], "duration_millis": 8821, "variants": [{"content_type": "application/x-mpegURL", "url": "https://video.twimg.com/amplify_video/2050154275020410880/pl/n4J2mnoEubeeHrrc.m3u8?tag=27"}, {"bitrate": 256000, "content_type": "video/mp4", "url": "https://video.twimg.com/amplify_video/2050154275020410880/vid/avc1/528x270/R_-jJkzAMgidS8Ne.mp4?tag=27"}, {"bitrate": 832000, "content_type": "video/mp4", "url": "https://video.twimg.com/amplify_video/2050154275020410880/vid/avc1/886x452/rpe_0L4kgEuHOPBa.mp4?tag=27"}]}}]}, "card": null, "place": {}, "entities": {"hashtags": [], "symbols": [{"indices": [9, 14], "text": "SOFI"}], "timestamps": [], "urls": [], "user_mentions": []}, "quoted_tweet": null, "retweeted_tweet": null, "isLimitedReply": false, "communityInfo": null, "article": null}, {"type": "tweet", "id": "2050156174012711292", "url": "https://x.com/realroseceline/status/2050156174012711292", "twitterUrl": "https://twitter.com/realroseceline/status/2050156174012711292", "text": "@TheRayMyers Your inexperience is causing you to ask the wrong questions.\n\nWith $SOFI, it\u2019s not about \u201care they growing?\u201d It\u2019s about \u201care they lending well?\u201d\n\nI almost never see bulls ask that. It\u2019s always revenue up, EBITDA up, EPS up, and then shock when the stock doesn\u2019t move or goes down. But this isn\u2019t $AAPL, it\u2019s a lending business. You have to look at it completely differently, mainly the balance sheet. \n\nDo they have a real funding advantage and are deposits actually sticky? Is underwriting great or are they just pushing volume to show growth? What do returns look like after losses? Are they building a relationship with the customer and cross selling higher margin products, or just originating loans and moving on? \n\nBecause lending can look amazing on the way up. You can grow really fast and everything looks amazing, numbers look strong, story sounds great. \n\nAnd then the cycle turns and the market isn\u2019t dumb. It\u2019s asking a different question. Not what it looks like today, but what it looks like when things get harder when they cycle turns. \n\nThis business and all lending / credit businesses as a whole are far more difficult and complex than what initially meets the eye\u2026 \n\n\ud83c\udf39", "source": "Twitter for iPhone", "re