0ad\u30e3\u30bf\u30d4\u30e9\u30fc $CAT\n2026\u5e74\u5ea6Q1\u6c7a\u7b97\u3092\u767a\u8868\u203c\ufe0f\n\u30c7\u30fc\u30bf\u30bb\u30f3\u30bf\u30fc\u95a2\u9023\u306e\u96fb\u529b\u8a2d\u5099\u9700\u8981\u3067\u3001\n\u53d7\u6ce8\u6b8b\u304c\u53f2\u4e0a\u6700\u9ad8\u6c34\u6e96\u3092\u66f4\u65b0\ud83d\udcc8\n\u682a\u4fa1\u306f\u6c7a\u7b97\u767a\u8868\u5f8c+9.88%\u6025\u9a30\u3067\u53d6\u5f15\u3092\u7d42\u3048\u308b\ud83d\ude80\n\n\ud83d\udd38FY26 Q1\u696d\u7e3e\n\u2b55\ufe0fEPS: 5.54\u30c9\u30eb(\u4e88\u60f34.64\u30c9\u30eb)\n\u2b55\ufe0f\u58f2\u4e0a\u9ad8: 174\u5104\u30c9\u30eb(\u4e88\u60f3164.4\u5104\u30c9\u30eb)\n\ud83d\udcc8\u58f2\u4e0a\u9ad8\u6210\u9577\u7387: +22% Y/Y\n\n\ud83d\udd38FY26 Q2\u30ac\u30a4\u30c0\u30f3\u30b9\n\u2714\ufe0f\u58f2\u4e0a\u9ad8: \u524d\u5e74\u540c\u671f\u6bd4\u3067\u5897\u53ce\u3092\u898b\u8fbc\u3080\n\n\ud83d\udd38FY26 \u901a\u671f\u30ac\u30a4\u30c0\u30f3\u30b9(\u66f4\u65b0)\n\u2714\ufe0f\u58f2\u4e0a\u9ad8\u6210\u9577\u7387: \u4f4e\u30442\u6841\u53f0\u306e\u6210\u9577(\u524d\u56de\u4e88\u60f3\u304b\u3089\u4e0a\u65b9\u4fee\u6b63)\n\n\ud83d\udd38\u53d7\u6ce8\u6b8b(\u30aa\u30fc\u30c0\u30fc\u30d0\u30c3\u30af\u30ed\u30b0)\n\ud83d\udcc8\u53d7\u6ce8\u6b8b: 627\u5104\u30c9\u30eb(\u53f2\u4e0a\u6700\u9ad8\u6c34\u6e96\ud83c\udfc6)\n\ud83d\udcc8\u524d\u5e74\u540c\u671f\u6bd4: +277\u5104\u30c9\u30eb(+79%)\n\ud83d\udcc8\u524d\u56db\u534a\u671f\u6bd4: +115\u5104\u30c9\u30eb\n\n\ud83d\udd38\u30bb\u30b0\u30e1\u30f3\u30c8\u5225\u696d\u7e3e\n\n\u3010\u30d1\u30ef\u30fc\uff06\u30a8\u30cd\u30eb\u30ae\u30fc\u3011\n\ud83d\udcc8\u58f2\u4e0a\u9ad8: 70\u5104\u30c9\u30eb(+22% Y/Y)\n\ud83d\udcc8\u30bb\u30b0\u30e1\u30f3\u30c8\u5229\u76ca: 14.5\u5104\u30c9\u30eb(+13% Y/Y)\n\u2714\ufe0f\u5229\u76ca\u7387: 20.6%(\u524d\u5e7422.3%\u304b\u3089\u4f4e\u4e0b \u203b\u95a2\u7a0e\u30b3\u30b9\u30c8\u5f71\u97ff)\n\u2714\ufe0f\u767a\u96fb\u5411\u3051\u58f2\u4e0a\u304c+41%\u3068\u6025\u4f38(\u30c7\u30fc\u30bf\u30bb\u30f3\u30bf\u30fc\u5411\u3051\u5927\u578b\u5f80\u5fa9\u52d5\u30a8\u30f3\u30b8\u30f3\u30fb\u30bf\u30fc\u30d3\u30f3\u304c\u727d\u5f15)\n\u2714\ufe0f\u77f3\u6cb9\u30fb\u30ac\u30b9\u5411\u3051: +13%\u3001\u7523\u696d\u5411\u3051: +5%\n\n\u3010\u30b3\u30f3\u30b9\u30c8\u30e9\u30af\u30b7\u30e7\u30f3\u30fb\u30a4\u30f3\u30c0\u30b9\u30c8\u30ea\u30fc\u30ba\u3011\n\ud83d\udcc8\u58f2\u4e0a\u9ad8: 71.6\u5104\u30c9\u30eb(+38% Y/Y)\n\ud83d\udcc8\u30bb\u30b0\u30e1\u30f3\u30c8\u5229\u76ca: 15.4\u5104\u30c9\u30eb(+50% Y/Y)\n\ud83d\udcc8\u5229\u76ca\u7387: 21.4%(\u524d\u5e7419.8%\u304b\u3089\u6539\u5584)\n\u2714\ufe0f\u5317\u7c73+48%\u3001\u4e2d\u5357\u7c73+29%\u3001EAME+38%\u3068\u5168\u5730\u57df\u3067\u597d\u8abf\n\u2714\ufe0f\u30c7\u30a3\u30fc\u30e9\u30fc\u5728\u5eab\u306e\u5897\u52a0(\u524d\u5e74\u540c\u671f\u306f\u5fae\u6e1b)\u304c\u8ca9\u58f2\u30dc\u30ea\u30e5\u30fc\u30e0\u62bc\u3057\u4e0a\u3052\n\n\u3010\u30ea\u30bd\u30fc\u30b9\u30fb\u30a4\u30f3\u30c0\u30b9\u30c8\u30ea\u30fc\u30ba\u3011\n\ud83d\udcc8\u58f2\u4e0a\u9ad8: 38\u5104\u30c9\u30eb(+4% Y/Y)\n\ud83d\udcc9\u30bb\u30b0\u30e1\u30f3\u30c8\u5229\u76ca: 3.78\u5104\u30c9\u30eb(\u25b239% Y/Y)\n\ud83d\udcc9\u5229\u76ca\u7387: 10.0%(\u524d\u5e7417.0%\u304b\u3089\u5927\u5e45\u4f4e\u4e0b)\n\u26a0\ufe0f\u88fd\u9020\u30b3\u30b9\u30c8\u306e\u60aa\u5316(\u4e3b\u306b\u95a2\u7a0e\u30b3\u30b9\u30c8)\u304c\u5229\u76ca\u3092\u76f4\u6483\n\n\u3010\u30d5\u30a3\u30ca\u30f3\u30b7\u30e3\u30eb\u30fb\u30d7\u30ed\u30c0\u30af\u30c4\u3011\n\ud83d\udcc8\u58f2\u4e0a\u9ad8: 11\u5104\u30c9\u30eb(+9% Y/Y)\n\ud83d\udcc8\u30bb\u30b0\u30e1\u30f3\u30c8\u5229\u76ca: 2.45\u5104\u30c9\u30eb(+14% Y/Y)\n\u2714\ufe0f\u5e73\u5747\u904b\u7528\u8cc7\u7523\u306e\u5897\u52a0\u30fb\u4fdd\u967a\u30b5\u30fc\u30d3\u30b9\u306e\u30de\u30fc\u30b8\u30f3\u6539\u5584\u304c\u5bc4\u4e0e\n\n\ud83d\udd38\u682a\u4e3b\u9084\u5143\u30fb\u8ca1\u52d9\u72b6\u6cc1\n\ud83d\udcc8\u682a\u4e3b\u9084\u5143: Q1\u306b57\u5104\u30c9\u30eb\u3092\u682a\u4e3b\u306b\u9084\u5143\n\u2714\ufe0f\u3046\u3061\u81ea\u793e\u682a\u8cb7\u3044: \u7d0450\u5104\u30c9\u30eb(4.5\u5104\u30c9\u30eb\u306eASR\u542b\u3080)\n\u2714\ufe0f\u914d\u5f53: 7\u5104\u30c9\u30eb\n\u2714\ufe0f\u30a8\u30f3\u30bf\u30fc\u30d7\u30e9\u30a4\u30ba\u73fe\u91d1\u6b8b\u9ad8: 41\u5104\u30c9\u30eb\n\n\ud83d\udd38CEO\u30b3\u30e1\u30f3\u30c8(Joe Creed\u6c0f)\n\u300c\u30c1\u30fc\u30e0\u306f\u3001\u5805\u8abf\u306a\u30a8\u30f3\u30c9\u30de\u30fc\u30b1\u30c3\u30c8\u3068\u52d5\u7684\u306a\u7d4c\u55b6\u74b0\u5883\u306e\u4e2d\u3067\u306e\u898f\u5f8b\u3042\u308b\u5b9f\u884c\u306b\u3088\u308a\u3001\u5e74\u521d\u304b\u3089\u529b\u5f37\u3044\u30b9\u30bf\u30fc\u30c8\u3092\u5207\u308b\u3053\u3068\u304c\u3067\u304d\u307e\u3057\u305f\u3002\u5805\u8abf\u306a\u58f2\u4e0a\u6210\u9577\u3068\u6d3b\u767a\u306a\u53d7\u6ce8\u6d3b\u52d5\u306f\u3001\u4e8b\u696d\u306e\u5f37\u3055\u3068\u9867\u5ba2\u306e\u56f0\u96e3\u306a\u8ab2\u984c\u3092\u89e3\u6c7a\u3059\u308b\u3053\u3068\u3078\u306e\u6ce8\u529b\u3092\u793a\u3057\u3066\u3044\u307e\u3059\u3002\u53f2\u4e0a\u6700\u9ad8\u306e\u53d7\u6ce8\u6b8b\u306f\u3001\u5f15\u304d\u7d9a\u304d\u30dd\u30b8\u30c6\u30a3\u30d6\u306a\u30e2\u30e1\u30f3\u30bf\u30e0\u306e\u5f37\u56fa\u306a\u57fa\u76e4\u3092\u63d0\u4f9b\u3057\u3066\u3044\u307e\u3059\u3002\u300d\n\n\ud83d\udd38\u4f1a\u793e\u6982\u8981\n\u30ad\u30e3\u30bf\u30d4\u30e9\u30fc\u306f100\u5e74\u4ee5\u4e0a\u306b\u308f\u305f\u308a\u3001\u3088\u308a\u826f\u304f\u6301\u7d9a\u53ef\u80fd\u306a\u4e16\u754c\u306e\u69cb\u7bc9\u306b\u8ca2\u732e\u3057\u3066\u304d\u305f\u4e16\u754c\u6700\u5927\u306e\u5efa\u8a2d\u30fb\u9271\u5c71\u6a5f\u68b0\u30e1\u30fc\u30ab\u30fc\u3067\u3059\u30022025\u5e74\u306e\u58f2\u4e0a\u9ad8\u306f676\u5104\u30c9\u30eb\u3002\n\u30d1\u30ef\u30fc\uff06\u30a8\u30cd\u30eb\u30ae\u30fc\u3001\u30b3\u30f3\u30b9\u30c8\u30e9\u30af\u30b7\u30e7\u30f3\u30fb\u30a4\u30f3\u30c0\u30b9\u30c8\u30ea\u30fc\u30ba\u3001\u30ea\u30bd\u30fc\u30b9\u30fb\u30a4\u30f3\u30c0\u30b9\u30c8\u30ea\u30fc\u30ba\u306e3\u30bb\u30b0\u30e1\u30f3\u30c8\u3092\u4e2d\u5fc3\u306b\u3001\u5efa\u8a2d\u6a5f\u68b0\u3001\u9271\u5c71\u6a5f\u68b0\u3001\u8236\u752