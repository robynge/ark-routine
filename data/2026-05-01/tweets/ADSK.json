": "https://t.co/x9YbI9fkhC"}]}}}, "isAutomated": false, "automatedBy": null}, "extendedEntities": {}, "card": null, "place": {}, "entities": {"hashtags": [], "symbols": [], "timestamps": [], "urls": [], "user_mentions": []}, "quoted_tweet": null, "retweeted_tweet": null, "isLimitedReply": false, "communityInfo": null, "article": null}, {"type": "tweet", "id": "2049945977298026548", "url": "https://x.com/adskflowstudio/status/2049945977298026548", "twitterUrl": "https://twitter.com/adskflowstudio/status/2049945977298026548", "text": "Your next quest starts here. \ud83d\uddfa\ufe0f  \n\nGenerate your character using Text to 3D, rig in just a few clicks, then bring it to life with AI mocap in Flow Studio\u2019s Live Action projects.\n\nRefine the shot with Neural Layer, or export for full control to take it further.\n\nFrom idea to performance, all in one tool.\n\nGet started: https://t.co/PA4n9lF2uG", "source": "Twitter for iPhone", "retweetCount": 9, "replyCount": 0, "likeCount": 38, "quoteCount": 0, "viewCount": 2616, "createdAt": "Thu Apr 30 20:16:21 +0000 2026", "lang": "en", "bookmarkCount": 35, "isReply": false, "inReplyToId": null, "conversationId": "2049945977298026548", "displayTextRange": [0, 274], "inReplyToUserId": null, "inReplyToUsername": null, "author": {"type": "user", "userName": "adskflowstudio", "url": "https://x.com/adskflowstudio", "twitterUrl": "https://twitter.com/adskflowstudio", "id": "1217211172140634112", "name": "Autodesk Flow Studio", "isVerified": false, "isBlueVerified": true, "verifiedType": null, "profilePicture": "https://pbs.twimg.com/profile_images/1633531431514431488/4JO5Kytf_normal.png", "coverPicture": "https://pbs.twimg.com/profile_banners/1217211172140634112/1678299218", "description": "", "location": "Los Angeles, CA", "followers": 42503, "following": 58, "status": "", "canDm": true, "canMediaTag": true, "createdAt": "Tue Jan 14 22:25:40 +0000 2020", "entities": {"description": {"urls": []}, "url": {}}, "fastFollowersCount":