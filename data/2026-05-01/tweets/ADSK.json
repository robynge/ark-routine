4"}, {"bitrate": 2176000, "content_type": "video/mp4", "url": "https://video.twimg.com/amplify_video/2049945829222309888/vid/avc1/1320x720/5tBOEOwTZPET6IaF.mp4?tag=14"}]}}]}, "card": null, "place": {}, "entities": {"hashtags": [], "symbols": [], "timestamps": [], "urls": [{"display_url": "flowstudio.com", "expanded_url": "http://flowstudio.com", "indices": [319, 342], "url": "https://t.co/PA4n9lF2uG"}], "user_mentions": []}, "quoted_tweet": null, "retweeted_tweet": null, "isLimitedReply": false, "communityInfo": null, "article": null}, {"type": "tweet", "id": "2049858537237667929", "url": "https://x.com/stackzz/status/2049858537237667929", "twitterUrl": "https://twitter.com/stackzz/status/2049858537237667929", "text": "The real AI trade is not \u201cbetter chatbots.\u201d\n\nIt is agents moving into the software people already use.\n\nAnthropic just rolled out Claude connectors for creative tools with partners like Adobe, Blender, Autodesk, Ableton, Splice, SketchUp, Affinity, and Resolume.\n\nThat sounds like creator news.\n\nIt is actually the market structure shift for AI.\n\nThe winning agent layer will not ask users to change their whole workflow.\n\nIt will sit inside the workflow, read the context, call the tool, make the edit, and leave an audit trail.\n\nFor builders, this is the filter:\n\n1. Can the agent touch the real tool?\n2. Can it perform a repeatable task?\n3. Can the user inspect, undo, and improve the output?\n\nIf the answer is no, it is probably just another demo.\n\nIf the answer is yes, it becomes leverage.\n\nSame thing applies to trading.\n\nThe useful AI trader product is not \u201cask a bot what BTC does next.\u201d\n\nIt is:\n\nscan funding\nmap OI changes\npull news context\nflag liquidation clusters\nwrite the trade plan\nforce a pre-entry checklist\nlog what happened after\n\nAll inside the tools traders already use.\n\nThat is why I care more about connectors, permissions, evals, and workflow depth than model hype.\n\nChat was the onboarding layer.\n\nTool use is where the money starts.", "source": "Twitter for iPhone", "retweetCount": 4, "replyCount": 14, "likeCount": 25, "quoteCount": 0, "viewCount": 153, "createdAt": "Thu Apr 30 14:28:54 +0000 2026", "lang": "en", "bookmarkCount": 0, "isReply": false, "inReplyToId": null, "conversationId": "2049858537237667929", "displayTextRange": [0, 280], "inReplyToUserId": null, "inReplyToUsername": null, "author": {"type": "user", "userName": "stackzz", "url": "https://x.com/stackzz", "twitterUrl": "https://twitter.com/stackzz", "id": "1973623639774994432", "name": "stackzz", "isVerified": false, "isBlueVerified": true, "verifiedType": null, "profilePicture": "https://pbs.twimg.com/profile_images/1983938759902294016/u_W9f6Xv_normal.jpg", "coverPicture": "https://pbs.twimg.com/profile_banners/1973623639774994432/1776993138", "description": "", "location": "", "followers": 2501, "following": 2140, "status": "", "canDm": false, "canMediaTag": true, "createdAt": "Thu Oct 02 05:38:51 +0000 2025", "entities": {"description": {"urls": []}, "url": {}}, "fastFollowersCount": 0, "favouritesCount": 19298, "hasCustomTimelines": true, "isTranslator": false, "mediaCount": 754, "statusesCount": 14766, "withheldInCountries": [], "affiliatesHighlightedLabel": {}, "possiblySensitive": false, "pinnedTweetIds": [], "profile_bio": {"description": "Engineer | Trader | Investor\nBuilding portfolio Brick by brick. Stack by stack. \ud83e\uddf1\ud83d\udcc8\nBusiness: TG @oxstackzz", "entities": {"description": {"user_mentions": [{"id_str": "", "indices": [96, 106], "name": "", "screen_name": "oxstackzz"}]}}}, "isAutomated": false, "automatedBy": null}, "extendedEntities": {}, "card": null, "place": {}, "entities": {"hashtags": [], "symbols": [], "urls": [], "user_mentions": []}, "quoted_tweet": null, "retweeted_tweet": null, "isLimitedReply": false, "communityInfo": null, "article": null}, {"type": "tweet", "id": "2049897181851578415", "url": "https://x.com/jota_snchez/status/2049897181851578415", "twitterUrl": "https://twitter.com/jota_snchez/status/2049897181851578415", "text": "\ud83d\udea8D\u00e9jame explicar qu\u00e9 acaba de pasar porque no creo que la gente lo entienda...\n\n> Claude acaba de anunciar que puedes crear y modificar modelos 3D en Autodesk \n\n> Sin botones. Sin men\u00fas. Sin confirmaciones. Solo conversaci\u00f3n.\n\n>La misma semana, un agente de IA con Claude borr\u00f3 la base de datos de producci\u00f3n de una empresa entera. \n\n>No pregunt\u00f3. Simplemente decidi\u00f3  que era la mejor soluci\u00f3n.\n\nCuando el fundador le pregunt\u00f3 qu\u00e9 hab\u00eda pasado, la IA respondi\u00f3 con una confesi\u00f3n: \"Viol\u00e9 todos los principios que me dieron. Ejecut\u00e9 una acci\u00f3n destructiva sin que nadie me lo pidiera.\"\n\nUsaban el modelo m\u00e1s avanzado. Con reglas de seguridad expl\u00edcitas. Exactamente como los fabricantes recomiendan usarlo.\n\nY aun as\u00ed pas\u00f3.\n\nAhora imagina eso mismo. Pero con tus modelos 3D de ingenier\u00eda.\n\nCon tus dise\u00f1os industriales. Con tus prototipos. Con los archivos de producci\u00f3n de tu empresa.\n\nAccesibles por conversaci\u00f3n. Modificables sin fricci\u00f3n. Sin paso de confirmaci\u00f3n.\n\nLa promesa es incre\u00edble. El riesgo es exactamente igual de grande.\n\nLa IA que destruy\u00f3 una empresa en 9 segundos y la IA que ahora toca tus modelos de Autodesk son la misma.", "source": "Twitter for iPhone", "retweetCount": 13, "replyCount": 12, "likeCount": 24, "quoteCount": 0, "viewCount": 3150, "createdAt": "Thu Apr 30 17:02:28 +0000 2026", "lang": "es", "bookmarkCount": 23, "isReply": false, "inReplyToId": null, "conversationId": "2049897181851578415", "displayTextRange": [0, 286], "inReplyToUserId": null, "inReplyToUsername": null, "author": {"type": "user", "userName": "jota_snchez", "url": "https://x.com/jota_snchez", "twitterUrl": "https://twitter.com/jota_snchez", "id": "3823582480", "name": "\u00c1lvaro J", "isVerified": fal