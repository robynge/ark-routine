"isAutomated": false, "automatedBy": null}, "extendedEntities": {"media": [{"allow_download_status": {"allow_download": true}, "display_url": "pic.twitter.com/wLlbULQaQi", "expanded_url": "https://twitter.com/dontstopinvest/status/2050160583266455713/photo/1", "ext_media_availability": {"status": "Available"}, "features": {"large": {"faces": []}, "orig": {"faces": []}}, "id_str": "2050160531252850688", "indices": [178, 201], "media_key": "3_2050160531252850688", "media_results": {"id": "QXBpTWVkaWFSZXN1bHRzOgwAAQoAARxzoiQV2jAACgACHHOiMDIa0KEAAA==", "result": {"__typename": "ApiMedia", "id": "QXBpTWVkaWE6DAABCgABHHOiJBXaMAAKAAIcc6IwMhrQoQAA", "media_key": "3_2050160531252850688"}}, "media_url_https": "https://pbs.twimg.com/media/HHOiJBXaMAAxdcF.jpg", "original_info": {"focus_rects": [{"h": 1004, "w": 1792, "x": 0, "y": 0}, {"h": 1191, "w": 1191, "x": 433, "y": 0}, {"h": 1191, "w": 1045, "x": 506, "y": 0}, {"h": 1191, "w": 596, "x": 730, "y": 0}, {"h": 1191, "w": 1792, "x": 0, "y": 0}], "height": 1191, "width": 1792}, "sizes": {"large": {"h": 1191, "w": 1792}}, "type": "photo", "url": "https://t.co/wLlbULQaQi"}]}, "card": null, "place": {}, "entities": {"hashtags": [], "symbols": [{"indices": [0, 5], "text": "META"}], "urls": [], "user_mentions": []}, "quoted_tweet": null, "retweeted_tweet": null, "isLimitedReply": false, "communityInfo": null, "article": null}, {"type": "tweet", "id": "2050148496339095997", "url": "https://x.com/adaora_crypto/status/2050148496339095997", "twitterUrl": "https://twitter.com/adaora_crypto/status/2050148496339095997", "text": "$META is down nearly 10% after earnings, losing over $150 billion in market cap. \n\nThe stock's significant decline follows a disappointing earnings report. \n\n$META's market cap drop is one of the largest recent losses.\n\nWhy did this happen ?\n\nLet\u2019s break it down.\n\nThe drop wasn\u2019t because Meta\u2019s earnings were bad, it was because investors ain\u2019t sure of what\u2019s coming next. \n\nThe real reasons the stocks dropped \n\n1\ud83d\udcccMassive Ai spending scared investors : Meta shocked the market by raising its 2026 spending (Capex) $125B - $145B\n\n\u2022That\u2019s tens of billions more than expected \n\n\u2022Most of it is going into Ai infrastructure (data centers,infrastructures and chips etc)\n\nSo investors are asking, when are we actually going to see returns on all this money, to them, the answer is unclear.\n\n2\ud83d\udcccProfit quality concerns \nEven though earnings looked strong , part of the profit came from a tax benefit .(one off boost)\n\nTo investors , future earnings may not look as strong so they are discounting today\u2019s good numbers .\n\n3\ud83d\udcccHuge spending = Less cash left over : lower free cash flow + Less room for stock buy backs .\nThat\u2019s bearish for stock prices in the short term .\n\n4\ud83d\udccc\u201dSpend now\u201d maybe profit \u201clater\u201d narrative .\n\nThis is the big one:\n\nMeta is going all In on Ai but:\n\u2022No clear timelines for pay off\n\u2022No cloud business like Amazon or Microsoft to monetize Ai quickly .\n\nAn investor\u2019s greatest fear is \u201cUncertainty\u201d.\n\nWhen you hold a stock study the company closes .\n\nDoesn\u2019t matter if it is already a bluechip or not.\n\nThat is what smart investors do.", "source": "Twitter for iPhone", "retweetCount": 1, "replyCount": 0, "likeCount": 13, "quoteCount": 0, "viewCount": 346, "createdAt": "Fri May 01 09:41:06 +0000 2026", "lang": "en", "bookmarkCount": 0, "isReply": false, "inReplyToId": null, "conversationId": "2050148496339095997", "displayTextRange": [0, 280], "inReplyToUserId": null, "inReplyToUsername": null, "author": {"type": "user", "userName": "adaora_crypto", "url": "https://x.com/adaora_crypto", "twitterUrl": "https://twitter.com/adaora_crypto", "id": "1435733142", "name": "Adaora Favour Nwankwo", "isVerified": false, "isBlueVerified": true, "verifiedType": null, "profilePicture": "https://pbs.twimg.com/profile_images/2039336101190811648/yG4z2ZuK_normal.jpg", "coverPicture": "https://pbs.twimg.com/profile_banners/1435733142/1763217552", "description": "", "location": "Portharcourt, Nigeria", "followers": 61218, "following": 980, "status": "", "canDm": true, "canMediaTag": true, "createdAt": "Fri May 17 14:05:31 +0000 2013", "entities": {"description": {"urls": []}, "url": {}}, "fastFollowersCount": 0, "favouritesCount": 82894, "hasCustomTimelines": true, "isTranslator": false, "mediaCount": 2987, "statusesCount": 23460, "withheldInCountries": [], "affiliatesHighlightedLabel": {}, "possiblySensitive": false, "pinnedTweetIds": ["2039632802736414729"], "profile_bio": {"description": "Board member @Nibiahq | Project idea strategist| Stock|Crypto|Culture shaper|Non-Conformist|Lodestar", "entities": {"description": {"user_mentions": [{"id_str": "", "indices": [13, 21], "name": "", "screen_name": "Nibiahq"}]}, "url": {"urls": [{"display_url": "cryptomaestroacademy.selar.com/stock-money", "expanded_url": "https://cryptomaestroacademy.selar.com/stock-money", "indices": [0, 23], "url": "https://t.co/bxO0kz77j7"}]}}}, "isAutomated": false, "automatedBy": null}, "extendedEntities": {}, "card": null, "place": {}, "entities": {"hashtags": [], "symbols": [{"indices": [0, 5], "text": "META"}, {"indices": [158, 163], "text": "META"}], "urls": [], "user_mentions": []}, "quoted_tweet": null, "retweeted_tweet": null, "isLimitedReply": false, "communityInfo": null, "article": null}, {"type": "tweet", "id": "2050158976092848154", "url": "https://x.com/MikeLongTerm/status/2050158976092848154", "twitterUrl": "https://twitter.com/MikeLongTerm/status/2050158976092848154", "text": "$AMD $META Dr. Su comment\ud83e\udd1d\n\n\"We actually see an opportunity to go much broader than that in the sense that you're actually charting the path for where AI infrastructure is going in the future.  So the value that's accrued to AMD of a deal like this is, yes, we get to accelerate purchases, which is a great thing, but we also get to accelerate our technology ecosystem, our software ecosystem that accrues benefits beyond just the work that we're doing with Meta, but really to the overall AMD ecosystem.  And the key with how we've designed these warrants is they're very, very performance-based.  So in some sense, both companies are incented to help each other win.  We win when Meta's foundational models are super successful and they need lots and lots of chips, so we are motivated to give them the best infrastructure for their workloads.  And they're motivated to ensure that our ecosystem is as strong as it can be.  And there's a very good win-win synergistic partnership.  But it is a special thing.  I think the conversation is around we want to build a very rich ecosystem.\"", "source": "Twitter for iPhone", "retweetCount": 0, "replyCount": 1, "likeCount": 12, "quoteCount": 0, "viewCount": 902, "createdAt": "Fri May 01 10:22:44 +0000 2026", "lang": "en", "bookmarkCount": 1, "isReply": false, "inReplyToId": null, "conversationId": "2050158976092848154", "displayTextRange": [0, 278], "inReplyToUserId": null, "inReplyToUsername": null, "author": {"type": "user", "userName": "MikeLongTerm", "url": "https://x.com/MikeLongTerm", "twitterUrl": "https://twitter.com/MikeLongTerm", "id": "1280587925336530948", "name": "Mike", "isVerified": false, "isBlueVerified": true, "verifiedType": null, "profilePicture": "https://pbs.twimg.com/profile_images/1532356424453480448/hGjaGQoQ_normal.jpg", "coverPicture": "https://pbs.twimg.com/profile_banners/1280587925336530948/1694632431", "description": "", "location": "Tweets AREN'T Financial Advice", "followers": 23550, "following": 392, "status": "", "canDm": false, "canMediaTag": true, "createdAt": "Tue Jul 07 19:42:13 +0000 2020", "entities": {"description": {"urls": []}, "url": {}}, "fastFollowersCount": 0, "favouritesCount": 9339, "hasCustomTimelines": true, "isTranslator": false, "mediaCount": 8589, "statusesCount": 28248, "withheldInCountrie