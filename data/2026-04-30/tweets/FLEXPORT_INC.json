{"ticker": "FLEXPORT_INC", "company": "Flexport, Inc", "weight_sum": 0.06, "etfs": ["ARKVX", "ARKSX", "ARKSX"], "is_private": true, "query": "\"Flexport\" -is:retweet min_faves:10 since:2026-04-29 until:2026-05-01", "n_fetched": 2, "n_kept": 2, "n_dropped": 0, "kept": [{"type": "tweet", "id": "2049333825860514007", "url": "https://x.com/typesfast/status/2049333825860514007", "twitterUrl": "https://twitter.com/typesfast/status/2049333825860514007", "text": "CBP today told the Court of International Trade that they\u2019d rejected 49% of refunds filed on the first pass (37% of filed rejected and then 18% of entries rejected on the files that were accepted). \n\nFlexport\u2019s rejection rate on refunds filed for our customers so far was 3%.  \n\nClean customs data is worth tens of billions of dollars.\n\nWe\u2019ve now reached the point where not using Flexport for customs transactions is a serious liability for your business, bordering on fiduciary violation even.", "source": "Twitter for iPhone", "retweetCount": 5, "replyCount": 6, "likeCount": 151, "quoteCount": 1, "viewCount": 16829, "createdAt": "Wed Apr 29 03:43:53 +0000 2026", "lang": "en", "bookmarkCount": 18, "isReply": false, "inReplyToId": null, "conversationId": "2049333825860514007", "displayTextRange": [0, 275], "inReplyToUserId": null, "inReplyToUsername": null, "author": {"type": "user", "userName": "typesfast", "url": "https://x.com/typesfast", "twitterUrl": "https://twitter.com/typesfast", "id": "395978320", "name": "Ryan Petersen", "isVerified": false, "isBlueVerified": true, "verifiedType": null, "profilePicture": "https://pbs.twimg.com/profile_images/1905038055935037440/3QXcfuSu_normal.jpg", "coverPicture": "https://pbs.twimg.com/profile_banners/395978320/1742337845", "description": "", "location": "USA", "followers": 356524, "following": 2137, "status": "", "canDm": true, "canMediaTag": false, "createdAt": "Sat Oct 22 15:16:59 +0000 2011", "entities": {"description": {"urls": []}, "url": {}}, "fa