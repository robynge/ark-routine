 "Brian Armstrong", "isVerified": false, "isBlueVerified": true, "verifiedType": null, "profilePicture": "https://pbs.twimg.com/profile_images/1516832438818770944/n77EwnKU_normal.png", "coverPicture": "https://pbs.twimg.com/profile_banners/14379660/1739931003", "description": "", "location": "Earth", "followers": 2018927, "following": 808, "status": "", "canDm": false, "canMediaTag": true, "createdAt": "Mon Apr 14 01:10:52 +0000 2008", "entities": {"description": {"urls": []}, "url": {}}, "fastFollowersCount": 0, "favouritesCount": 9950, "hasCustomTimelines": true, "isTranslator": false, "mediaCount": 494, "statusesCount": 5238, "withheldInCountries": [], "affiliatesHighlightedLabel": {}, "possiblySensitive": false, "pinnedTweetIds": ["2039709713323962470"], "profile_bio": {"description": "Co-founder & CEO at @Coinbase. Creating more economic freedom in the world. ENS: barmstrong.eth Co-founder @researchhub @newlimit", "entities": {"description": {"user_mentions": [{"id_str": "", "indices": [20, 29], "name": "", "screen_name": "Coinbase"}, {"id_str": "", "indices": [107, 119], "name": "", "screen_name": "researchhub"}, {"id_str": "", "indices": [120, 129], "name": "", "screen_name": "newlimit"}]}, "url": {"urls": [{"display_url": "coinbase.com", "expanded_url": "https://www.coinbase.com/", "indices": [0, 23], "url": "https://t.co/YxEWIGGGmN"}]}}}, "isAutomated": false, "automatedBy": null}, "extendedEntities": {}, "card": null, "place": {}, "entities": {"hashtags": [], "symbols": [], "timestamps": [], "urls": [], "user_mentions": []}, "quoted_tweet": {"type": "tweet", "id": "2050325150747484421", "url": "", "twitterUrl": "", "text": "", "source": "Twitter for iPhone", "retweetCount": 0, "replyCount": 0, "likeCount": 0, "quoteCount": 0, "viewCount": 0, "createdAt": "", "lang": "", "bookmarkCount": 0, "isReply": false, "inReplyToId": null, "conversationId": "", "displayTextRange": [], "inReplyToUserId": null, "inReplyToUsername": null, "author": {}, "extendedEntities": {}, "card": null, "place": {}, "entities": {}, "quoted_tweet": null, "retweeted_tweet": null, "isLimitedReply": false, "communityInfo": null, "article": null}, "retweeted_tweet": null, "isLimitedReply": false, "communityInfo": null, "article": null}, "retweeted_tweet": null, "isLimitedReply": false, "communityInfo": null, "article": null}, {"type": "tweet", "id": "2050592490483581085", "url": "https://x.com/SweatyKodi/status/2050592490483581085", "twitterUrl": "https://twitter.com/SweatyKodi/status/2050592490483581085", "text": "CLARITY Act rewards is out!\n\nAfter months of debate, crypto didn\u2019t get shut out\n\nYes, banks pushed for tighter restrictions\n\nBut the industry still protected something important:\n\nAmericans can continue earning rewards \ntied to usage of crypto platforms and networks\n\n$ETH $BMNR", "source": "Twitter for iPhone", "retweetCount": 1, "replyCount": 2, "likeCount": 33, "quoteCount": 1, "viewCount": 1494, "createdAt": "Sat May 02 15:05:22 +0000 2026", "lang": "en", "bookmarkCount": 1, "isReply": false, "inReplyToId": null, "conversationId": "2050592490483581085", "displayTextRange": [0, 278], "inReplyToUserId": null, "inReplyToUsername": null, "author": {"type": "user", "userName": "SweatyKodi", "url": "https://x.com/SweatyKodi", "twitterUrl": "https://twitter.com/SweatyKodi", "id": "4847335961", "name": "Kodi (BMNR) \ud83d\udccc", "isVerified": false, "isBlueVerified": true, "verifiedType": null, "profilePicture": "https://pbs.twimg.com/profile_images/1943347772737916940/t1D73Nzg_normal.jpg", "coverPicture": "https://pbs.twimg.com/profile_banners/4847335961/1735236487", "description": "", "location": "Florida City, FL", "followers": 8504, "following": 5599, "status": "", "canDm": true, "canMediaTag": true, "createdAt": "Mon Jan 25 23:42:05 +0000 2016", "entities": {"description": {"urls": []}, "url": {}}, "fastFollowersCount": 0, "favouritesCount": 36219, "hasCustomTimelines": true, "isTranslator": false, "mediaCount": 1949, "statusesCount": 15824, "withheldInCountries": [], "affiliatesHighlightedLabel": {}, "possiblySensitive": false, "pinnedTweetIds": ["2050373947594867054"], "profile_bio": {"description": "In the process of building a Bitmine $BMNR cult. With hint of $TSLA news as well! Let\u2019s all stay connected!", "entities": {"description": {"symbols": [{"indices": [37, 42], "text": "BMNR"}, {"indices": [62, 67], "text": "TSLA"}]}}}, "isAutomated": false, "automatedBy": null}, "extendedEntities": {}, "card": null, "place": {}, "entities": {"hashtags": [], "symbols": [{"indices": [268, 272], "text": "ETH"}, {"indices": [273, 278], "text": "BMNR"}], "timestamps": [], "urls": [], "user_mentions": []}, "quoted_tweet": {"type": "tweet", "id": "2050325150747484421", "url": "https://x.com/faryarshirzad/status/2050325150747484421", "twitterUrl": "https://twitter.com/faryarshirzad/status/2050325150747484421", "text": "The final rewards text in the CLARITY Act is now public.\n\nWe\u2019ve been clear throughout this process: much of this debate was based on imagined risks, not real evidence, nor was it based on a real understanding of how crypto actually works.\n\nNevertheless, the crypto industry showed up to engage. Through months of meetings, the @WhiteHouse, @USTreasury, @BankingGOP, @SenThomTillis and @Sen_Alsobrooks finally arrived at a compromise.\n\nIn the end, the banks were able to get more restrictions on rewards, but we protected what matters \u2013 the ability for Americans to earn rewards, based on real usage of crypto platforms and networks. We also ensured the US can be at the forefront of the financial system \u2013 which in this competitive geopolitical era is paramount.\n\nThat\u2019s important for innovation, consumers and America's national security.\n\nNow that this issue is behind us, it\u2019s time to focus on the broader bill. While this debate has been underway, lots of progress has been made on other areas like token classification, defi, and tokenization. We\u2019re excited to review the full, final text, and for the bill to move forward.\n\nIt\u2019s time to get CLARITY done.", "source": "Twitter for iPhone", "retweetCount": 429, "replyCount": 136, "likeCount": 2156, "quoteCount": 89, "viewCount": 993008, "createdAt": "Fri May 01 21:23:03 +0000 2026", "lang": "en", "bookmarkCount": 332, "isReply": false, "inReplyToId": null, "conversationId": "2050325150747484421", "displayTextRange": [0, 280], "inReplyToUserId": null, "inReplyToUsername": null, "author": {"type": "user", "userName": "faryarshirzad", "url": "https://x.com/faryarshirzad", "twitterUrl": "https://twitter.com/faryarshirzad", "id": "359126146", "name": "Faryar Shirzad \ud83d\udee1\ufe0f", "isVerified": false, "isBlueVerified": true, "verifiedType": null, "profilePicture": "https://pbs.twimg.com/profile_images/2009484753104404480/vgwFRuvk_normal.jpg", "coverPicture": "https://pbs.twimg.com/profile_banners/359126146/1767933713", "description": "", "location": "Washington, DC", "followers": 14817, "following": 1650, "status": "", "canDm": false, "canMediaTag": true, "createdAt": "Sun Aug 21 02:17:55 +0000 2011", "entities": {"description": {"urls": []}, "url": {}}, "fastFollowersCount": 0, "favouritesCount": 6155, "hasCustomTimelines": true, "isTranslator": false, "mediaCount": 169, "statusesCount": 1909, "withheldInCountries": [], "affiliatesHighlightedLabel": {}, "possiblySensitive": false, "pinnedTweetIds": [], "profile_bio": {"description": "Chief Policy Officer @Coinbase.", "entities": {"description": {"user_mentions": [{"id_str": "", "indices": [21, 30], "name": "", "screen_name": "Coinbase"}]}}}, "isAutomated": false, "automatedBy": null}, "extendedEntities": {}, "card": null, "place": {}, "entities": {"hashtags": [], "symbols": [], "urls": [], "user_mentions": [{"id_str": "1879644163769335808", "indices": [327, 338], "name": "The White House", "screen_name": "WhiteHouse"}, {"id_str": "120176950", "indices": [340, 351], "name": "Treasury Department", "screen_