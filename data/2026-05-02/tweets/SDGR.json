 \u0647\u0645 \u062a\u0631\u0627\u0645\u067e \u0633\u0631 \u062c.\u0627 \u0648 \u0645\u06cc\u062f\u06cc\u0627 \u0631\u0648 \u0628\u0627 \u062f\u06cc\u0628\u06cc\u200c\u0628\u0627\u0632\u06cc\u200c\u0647\u0627\u0634 \u06af\u0631\u0645 \u06a9\u0631\u062f. \u062e\u0648\u0628 \u0627\u06cc\u0646 \u0627\u0632 \u0627\u06cc\u0646 \u0628\u062e\u0634.\n\n\u062f\u0631 \u0642\u062f\u0645 \u0628\u0639\u062f\u06cc \u0648 \u0628\u0631\u0627\u06cc \u0627\u0637\u0645\u06cc\u0646\u0627\u0646 \u0627\u0632 \u0622\u0631\u0627\u06cc\u0634\u200c\u0647\u0627\u06cc \u062c\u062f\u06cc\u062f\u060c \u067e\u06cc\u062f\u0627 \u06a9\u0631\u062f\u0646 \u0644\u0627\u0646\u0647 \u0627\u0631\u0632\u0634\u06cc\u200c\u0647\u0627\u060c \u062f\u0631 \u0686\u0646\u062f \u0631\u0648\u0632 \u0627\u062e\u06cc\u0631 \u0622\u0645\u0631\u06cc\u06a9\u0627 \u0648 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644 \u0634\u0631\u0648\u0639 \u0628\u0647 \u0633\u0631\u06a9 \u06a9\u0634\u06cc\u062f\u0646 \u0628\u0647 \u0627\u06cc\u0631\u0627\u0646 \u0648 \u0686\u0646\u062f\u06cc\u0646 \u0627\u0646\u0641\u062c\u0627\u0631 \u0648 \u067e\u0631\u0648\u0627\u0632 \u067e\u0647\u067e\u0627\u062f \u06a9\u0631\u062f\u0646\u062f. \u06a9\u0647 \u0627\u06cc\u0646\u0645 \u062e\u06cc\u0644\u06cc \u0627\u062e\u06cc\u0631 \u0647\u0633\u062a\u0634 \u0648 \u0647\u0645\u0647 \u0628\u0647 \u06cc\u0627\u062f \u062f\u0627\u0631\u0646\u062f.\n\n\u062f\u0631 \u0622\u0646 \u0637\u0631\u0641 \u0645\u0627\u062c\u0631\u0627\u060c \u0641\u0631\u0648\u0634 \u0648 \u0627\u0633\u062a\u0642\u0631\u0627\u0631 \u062a\u062c\u0647\u06cc\u0632\u0627\u062a \u062e\u06cc\u0644\u06cc \u067e\u06cc\u0634\u0631\u0641\u062a\u0647 \u0622\u0645\u0631\u06cc\u06a9\u0627\u06cc\u06cc \u0648 \u0627\u0633\u0631\u0627\u0626\u06cc\u0644\u06cc \u0628\u0647 \u06a9\u0634\u0648\u0631\u0647\u0627\u06cc \u0639\u0631\u0628\u06cc\u060c \u0645\u062e\u0635\u0648\u0635\u0627\u064b \u0631\u0641\u06cc\u0642 \u0634\u0641\u06cc\u0642 \u0648 \u0633\u0627\u0628\u0642 \u062c\u200c\u0627\u060c \u06c