, "entities": {"hashtags": [{"indices": [0, 12], "text": "NacionalCri"}], "media": [{"additional_media_info": {"monetizable": false}, "display_url": "pic.x.com/gVtPobMD3J", "expanded_url": "https://x.com/criticaenlinea/status/2049154164328890698/video/1", "ext_media_availability": {"status": "Available"}, "id_str": "2049153803018973184", "indices": [277, 300], "media_key": "7_2049153803018973184", "media_results": {"result": {"media_key": "7_2049153803018973184"}}, "media_url_https": "https://pbs.twimg.com/ext_tw_video_thumb/2049153803018973184/pu/img/YsDx6kHFrQEemzXB.jpg", "original_info": {"focus_rects": [], "height": 900, "width": 720}, "sizes": {"large": {"h": 900, "resize": "fit", "w": 720}, "medium": {"h": 900, "resize": "fit", "w": 720}, "small": {"h": 680, "resize": "fit", "w": 544}, "thumb": {"h": 150, "resize": "crop", "w": 150}}, "type": "video", "url": "https://t.co/gVtPobMD3J", "video_info": {"aspect_ratio": [4, 5], "duration_millis": 327893, "variants": [{"content_type": "application/x-mpegURL", "url": "https://video.twimg.com/ext_tw_video/2049153803018973184/pu/pl/wN9E5-XV4GZBTQ2T.m3u8?tag=19&v=bb3"}, {"bitrate": 632000, "content_type": "video/mp4", "url": "https://video.twimg.com/ext_tw_video/2049153803018973184/pu/vid/avc1/320x400/nSSw2gosE9Vp0vAk.mp4?tag=19"}, {"bitrate": 950000, "content_type": "video/mp4", "url": "https://video.twimg.com/ext_tw_video/2049153803018973184/pu/vid/avc1/480x600/YetAsRUqOdQXOK7O.mp4?tag=19"}, {"bitrate": 2176000, "content_type": "video/mp4", "url": "https://video.twimg.com/ext_tw_video/2049153803018973184/pu/vid/avc1/720x900/1eGb8e1D6nLEM-xm.mp4?tag=19"}]}}], "symbols": [], "timestamps": [], "urls": [], "user_mentions": []}, "quoted_tweet": null, "retweeted_tweet": null, "article": null}, {"type": "tweet", "id": "2049200496184082884", "url": "https://x.com/BaixSegura_es/status/2049200496184082884", "twitterUrl": "https://twitter.com/BaixSegura_es/status/2049200496184082884", "text": "\ud83c\uddec\ud83c\udde7A search is underway at General Electric Vernova (formerly part of the Alstom merger) in Castle Hayne, North Carolina. Is Emmanuel Macron in the crosshairs? Marshal McNeill Jr. and several FinCEN agents are on site, according to Kelly Ayotte's office. Suspicions include violation of the Bank Secrecy Act (BSA), insider trading, and tax evasion. In August 2014, Leon Black is suspected of having acquired an increasing number of GE shares for no apparent reason. Was this insider trading? Who could have informed him about the share price increase after the announcement of the negotiations with Alstom? Mr. Macron? The link between Mr. Leon Black and Mr. Macron is established by Bank of America's involvement in the Alstom sale deal, which ultimately netted the bank $10 million. Could some of this money have subsequently been returned as kickbacks? These are the questions that agents from FinCEN (Financial Crimes Enforcement Network) and a local US Marshals unit led by Glenn McNeill, nicknamed \"Nosy,\" are trying to answer. According to McNeill, L\u00e9on Black was able to transfer funds through his trust, Apollo Global Management. Kelly Ayotte's team, the former New Hampshire Attorney General, believes that a holding company in Saint Kitts and Nevis was used for this purpose. The Lichtkant Group was a shell company capable of paying kickbacks to ultimate beneficial owners. One of them, \"Osdorp,\" received substantial sums between August 2014 and August 2016, which corresponds to the period when Mr. Macron played a key role in the forced sale of Alstom to GE. The strategy appeared to be to force the sale under pressure from the Obama administration in order to initiate Mr. Black's involvement in the ongoing case and have Bank of America included in the Alstom sale mandate. Everyone benefited in one way or another. At some point, including the seller (E. Macron) through possible kickbacks, has Trump found his Achilles' heel? This is how several US investigations could well trip up the French president prematurely.", "source": "Twitter for iPhone", "retweetCount": 6, "replyCount": 1, "likeCount": 13, "quoteCount": 0, "viewCount": 310, "createdAt": "Tue Apr 28 18:54:05 +0000 2026", "lang": "en", "bookmarkCount": 1, "isReply": true, "inReplyToId": "2049121129885737101", "conversationId": "2049121129885737101", "displayTextRange": [17, 289], "inReplyToUserId": null, "inReplyToUsername": null, "author": {"type": "user", "userName": "BaixSegura_es", "url": "https://x.com/BaixSegura_es", "twitterUrl": "https://twitter.com/BaixSegura_es", "id": "272581021", "name": "PIK Y PIK \ud83d\udd4a\ufe0f\ud83d\udd4a\ufe0f\ud83d\udd4a\ufe0f", "isVerified": false, "isBlueVerified": true, "verifiedType": null, "profilePicture": "https://pbs.twimg.com/profile_images/2004244916717625344/exN_AM9W_normal.jpg", "coverPicture": "https://pbs.twimg.com/profile_banners/272581021/1777474771", "description": "L'exil est l'\u00e9tat d'une personne qui a quitt\u00e9 sa patrie \u2014 volontairement et/ou sous la contrainte \u2014 et qui vit dans un pays \u00e9tranger ici ou ailleurs  \ud83d\udd4a\ufe0f\ud83d\udd4a\ufe0f\ud83d\udd4a\ufe0f", "location": "Vinalop\u00f3,Cartagena, Alicante", "followers": 2368, "following": 2107, "status": "", "canDm": true, "canMediaTag": false, "createdAt": "Sat Mar 26 20:00:26 +0000 2011", "entities": {"description": {}}, "fastFollowersCount": 0, "favouritesCount": 122287, "hasCustomTimelines": true, "isTranslator": false, "mediaCount": 25916, "statusesCount": 543123, "withheldInCountries": [], "affiliatesHighlightedLabel": {}, "possiblySensitive": false, "pinnedTweetIds": ["2049218198147301885"], "profile_bio": {}, "isAutomated": false, "automatedBy": null}, "extendedEntities": {}, "card": null, "place": {}, "entities": {"hashtags": [], "symbols": [], "urls": [], "user_mentions": []}, "quoted_tweet": null, "retweeted_tweet": null, "article": null}], "dropped": [{"reason": "cashtags=9", "tweet": {"type": "tweet", "id": "2049132294875787278", "url"