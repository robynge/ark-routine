d": "2050785305809371427", "url": "https://x.com/shakoistsLog/status/2050785305809371427", "twitterUrl": "https://twitter.com/shakoistsLog/status/2050785305809371427", "text": "I set up a contextual retrieval system yesterday that bridged slack/gdocs/dashboard/database/datadog/main repos across two VMs and my personal computer and 3 or 4 agents.\n\nGoing between all the agents who were sharing context and solving my problems was not oldschool coding flow state, but it had a sort of flow vibe that was beautiful in its own right.", "source": "Twitter for iPhone", "retweetCount": 0, "replyCount": 3, "likeCount": 36, "quoteCount": 0, "viewCount": 2011, "createdAt": "Sun May 03 03:51:33 +0000 2026", "lang": "en", "bookmarkCount": 20, "isReply": false, "inReplyToId": null, "conversationId": "2050785305809371427", "displayTextRange": [0, 279], "inReplyToUserId": null, "inReplyToUsername": null, "author": {"type": "user", "userName": "shakoistsLog", "url": "https://x.com/shakoistsLog", "twitterUrl": "https://twitter.com/shakoistsLog", "id": "1574621478557208577", "name": "shako", "isVerified": false, "isBlueVerified": true, "verifiedType": null, "profilePicture": "https://pbs.twimg.com/profile_images/2025436082352128004/ULSe8-2__normal.jpg", "coverPicture": "https://pbs.twimg.com/profile_banners/1574621478557208577/1772604394", "description": "", "location": "Arendelle", "followers": 13330, "following": 2850, "status": "", "canDm": true, "canMediaTag": false, "createdAt": "Tue Sep 27 04:46:40 +0000 2022", "entities": {"description": {"urls": []}, "url": {}}, "fastFollowersCount": 0, "favouritesCount": 68245, "hasCustomTimelines": true, "isTranslator": false, "mediaCount": 1779, "statusesCount": 20844, "withheldInCountries": [], "affiliatesHighlightedLabel": {}, "possiblySensitive": false, "pinnedTweetIds": ["2015281638234841151"], "profile_bio": {"description": "post-ironic post-rationalist https://t.co/1QoefmwUlA", "entities": {"description": {"urls": [{"display_url": "substack.com/@shakoist", "expanded_url": "https://substack.com/@shakoist", "indices": [29, 52], "url": "https://t.co/1QoefmwUlA"}]}}}, "isAutomated": false, "automatedBy": null}, "extendedEntities": {}, "card": null, "place": {}, "entities": {"hashtags": [], "symbols": [], "urls": [], "user_mentions": []}, "quoted_tweet": {"type": "tweet", "id": "2050516749293101296", "url": "https://x.com/owen_venter/status/2050516749293101296", "twitterUrl": "https://twitter.com/owen_venter/status/2050516749293101296", "text": "Programming used to put me into FLOW state often. That\u2019s a big part of why I fell in love with it. Late night missions building games, apps, whatever, it felt great. \n\nMihaly Csikszentmihalyi has a great quote on this:\n\n\u201cThe best moments in our lives\u2026 occur when a person\u2019s body or mind is stretched to its limits in a voluntary effort to accomplish something difficult or worthwhile.\u201d\n\nAI has kind of nuked the personal challenge part of that. I don\u2019t fall into those same FLOW states nearly as often anymore. It\u2019s a strange position to be in because I\u2019m undeniably more productive, but some of the joy is gone. I still love building software, but now the enjoyment comes more from seeing products come to life and have real-world impact than from the actual process of writing the code.\n\nI\u2019ll miss the deep flow states that came from fighting code for hours into the night, but I feel like I do need to find new areas that still offer that same sense of challenge.", "source": "Twitter for iPhone", "retweetCount": 52, "replyCount": 60, "likeCount": 858, "quoteCount": 14, "viewCount": 49994, "createdAt": "Sat May 02 10:04:24 +0000 2026", "lang": "en", "bookmarkCount": 244, "isReply": false, "inReplyToId": null, "conversationId": "2050516749293101296", "displayTextRange": [0, 278], "inReplyToUserId": null, "inReplyToUsername": null, "author": {"type": "user", "userName": "owen_venter", "url": "https://x.com/owen_venter", "