dLabel": {}, "possiblySensitive": false, "pinnedTweetIds": ["2044376132221550747"], "profile_bio": {"description": "Founder @gitlawb - git platform for AI agents", "entities": {"description": {"user_mentions": [{"id_str": "", "indices": [8, 16], "name": "", "screen_name": "gitlawb"}]}}}, "isAutomated": false, "automatedBy": null}, "extendedEntities": {"media": [{"additional_media_info": {"monetizable": true}, "allow_download_status": {"allow_download": true}, "display_url": "pic.twitter.com/xrxTE0k1lP", "expanded_url": "https://twitter.com/kevincodex/status/2050562981596139945/video/1", "ext_media_availability": {"status": "Available"}, "id_str": "2050562853548253184", "indices": [163, 186], "media_key": "13_2050562853548253184", "media_results": {"id": "QXBpTWVkaWFSZXN1bHRzOgwABAoAARx1EA0LWuAAAAA=", "result": {"__typename": "ApiMedia", "id": "QXBpTWVkaWE6DAAECgABHHUQDQta4AAAAA==", "media_key": "13_2050562853548253184"}}, "media_url_https": "https://pbs.twimg.com/amplify_video_thumb/2050562853548253184/img/XmSOLTpr0o0U5tvW.jpg", "original_info": {"focus_rects": [], "height": 1704, "width": 2560}, "sizes": {"large": {"h": 1363, "w": 2048}}, "type": "video", "url": "https://t.co/xrxTE0k1lP", "video_info": {"aspect_ratio": [320, 213], "duration_millis": 14256, "variants": [{"content_type": "application/x-mpegURL", "url": "https://video.twimg.com/amplify_video/2050562853548253184/pl/TRkOq023EAUMyU5c.m3u8?tag=27"}, {"bitrate": 256000, "content_type": "video/mp4", "url": "https://video.twimg.com/amplify_video/2050562853548253184/vid/avc1/404x270/BPd689DQKskElJTQ.mp4?tag=27"}, {"bitrate": 832000, "content_type": "video/mp4", "url": "https://video.twimg.com/amplify_video/2050562853548253184/vid/avc1/540x360/9QDpUExLYyL3u3wm.mp4?tag=27"}, {"bitrate": 2176000, "content_type": "video/mp4", "url": "https://video.twimg.com/amplify_video/2050562853548253184/vid/avc1/1080x720/iAeEMuPM7yxJmqdo.mp4?tag=27"}, {"bitrate": 10368000, "content_type": "video/mp4", "url": "https://video.twimg.com/amplify_video/2050562853548253184/vid/avc1/1622x1080/9wUWX-TbRDdIJ4sZ.mp4?tag=27"}, {"bitrate": 25128000, "content_type": "video/mp4", "url": "https://video.twimg.com/amplify_video/2050562853548253184/vid/avc1/2560x1704/kmKswD9hXKwyqq1z.mp4?tag=27"}]}}]}, "card": null, "place": {}, "entities": {"hashtags": [], "symbols": [], "timestamps": [], "urls": [], "user_mentions": []}, "quoted_tweet": null, "retweeted_tweet": null, "isLimitedReply": false, "communityInfo": null, "article": null}, {"type": "tweet", "id": "2050590691156238761", "url": "https://x.com/esrtweet/status/2050590691156238761", "twitterUrl": "https://twitter.com/esrtweet/status/2050590691156238761", "text": "Calling all open-source developers!\n\nI've been thinking about @planefag's complaint and I have realized there's something easy and systematic we can do to address it.\n\nThe core problem is that because of the ABI problem, source repositories are almost never the right place to try to ship binaries from. We can't fix that, but there's something else we can do. \n\nSince a couple of months ago, every single one of my repositories on GitLab has a magic link in its README file, \n\nIt's a link to https://t.co/JMWFYOnbh0. which is the site that, given a stable package ID that usually corresponds to the most obvious name of a code distribution,  can tell you what distro repositories carry it and at what version. What the link presents is automatically updated whenever the database is. \n\nIf planefag wanted to get a binary for one of my projects, he could look at the table that link puts in my README and immediately see what name he should feed his package manager to fetch it with.\n\nAnd if it's not packaged for his distribution, he'd know that too.\n\nIt's not perfect, but it's way better than nothing.", "source": "Twitter for iPhone", "retweetCount": 4, "replyCount": 6, "likeCount": 49, "quoteCount": 1, "viewCount": 2714, "createdAt": "Sat May 02 14:58:13 +0000 2026", "lang": "en", "bookmarkCount": 9, "isReply": false, "inReplyToId": null, "conversationId": "2050590691156238761", "displayTextRange": [0, 280], "inReplyToUserId": null, "inReplyToUsername": null, "author": {"type": "user", "userName": "esrtweet", "url": "https://x.com/esrtweet", "twitterUrl": "https://twitter.com/esrtweet", "id": "147346374", "name": "Eric S. Raymond", "isVerified": false, "isBlueVerified": true, "verifiedType": null, "profilePicture": "https://pbs.twimg.com/profile_images/925069606/ecsllogo2_normal.png", "coverPicture": "", "description": "", "location": "", "followers": 50834, "following": 219, "status": "", "canDm": false, "canMediaTag": true, "createdAt": "Sun May 23 22:21:50 +0000 2010", "entities": {"description": {"urls": []}, "url": {}}, "fastFollowersCount": 0, "favouritesCount": 2098, "hasCustomTimelines": true, "isTranslator": false, "mediaCount": 34, "statusesCount": 11881, "withheldInCountries": [], "affiliatesHighlightedLabel": {}, "possiblySensitive": false, "pinnedTweetIds": [], "profile_bio": {"description": "Yes, I *am* that ESR. Well, it's the question people usually ask.\n\nProgrammer, wandering philosopher, accidental anthropologist, troublemaker for liberty.", "entities": {"description": {}, "url": {"urls": [{"display_url": "catb.org/~esr", "expanded_url": "http://catb.org/~esr", "indices": [0, 23], "url": "https://t.co/CWyCfQw8LX"}]}}}, "isAutomated": false, "automatedBy": null}, "extendedEntities": {}, "card": null, "place": {}, "entities": {"hashtags": [], "symbols": [], "urls": [{"display_url": "repology.org", "expanded_url": "http://repology.org", "indices": [493, 516], "url": "https://t.co/JMWFYOnbh0"}], "user_mentions": [{"id_str": "2818659595", "indices": [62, 71], "name": "planefag", "screen_name": "planefag"}]}, "quoted_tweet": {"type": "tweet", "id": "2050545594867798489", "url": "https://x.com/esrtweet/status/2050545594867798489", "twitterUrl": "https://twitter.com/esrtweet/status/2050545594867798489", "text": "planefag, I'm not excusing the attitude of the guy who pissed you off. But there is an explanation for it, and I'm going to put on my Mister Open Source hat and lay it on you.\n\nThe real reason there aren't prominent links to downloadable binaries on forge sites like GitHub is that in open-source land there is no such thing as a truly portable binary. \n\nWindows and Mac make binary distribution easy by being limited to a single hardware platform and a single ABI - application binary interface..\n\n(The assertion I just made can be quibbled with at the edges. I will be unkind to anyone who attempts this.)\n\nAn application binary interface is a set of conventions for how you decorate your binary so the operating system's program loader knows what to do with it, and how you write traps from your binary to call operating system services.\n\nWindows and Mac have, effectively, just one ABI each. So you can generate one binary for, say, Windows, attach it to a download link, and Windows users will generally not come back screaming for your blood because it fails to work in some obscure way. (Again, this statement can be quibbled with, but see this whacking great truncheon in my hand? Just don't.)\n\nThere is no such grace in open-source land.\n\nThere are a whole bunch of complicated historical reasons for this, starting with the fact that Linux runs on more different hardware architectures, and continuing with the fact that Linux isn't the only game in town (there are the BSDs), and continuing into technical minutiae that would make your head hurt, and continuing further into technical minutiae that make *my* head hurt.\n\nBut what this actually means is that if you want to provide binaries and not get sperg-screamed at, you can't just provide one. You'd have to provide many, and no matter how comprehensive you try to be somebody is going to be disgruntled because you didn't cover their corner case. \n\nThis is not a cost-free proposition. For each different kind of binary you provide, you need to cross-compile your source code in a different environment, many of them posted on distributions and hardware platforms you don't have routine access to.\n\nSo people almost never do it at all. \n\nBecause most projects don't do this, sites like GitHub don't see any demand push to make binary download links really accessible.\n\nInstead, the problem is normally handled at a different level. Your distribution maker keeps huge sets of compiled binaries lightly hidden inside of installable packages, tuned for the ABI of that single distribution. Your package manager hides from you the packages for everything but your hardware architecture\n\nThe person who pissed you off was rude, but he wasn't exactly wrong about the objective facts. What you want isn't practically possible. Instead of being annoyed because GitHub doesn't feature binary-download links, search for that software using your package manager.\n\nSometimes you won't find it. That's when you have to download source bust out a compiler. Sorry, but that's the way it is. We're trying as hard as we can - really, we are. But the complicated shape of the terrain constrains what we can achieve.", "source": "Twitter for iPhone", "retweetCount": 7, "replyCount": 19, "likeCount": 209, "quoteCount": 3, "viewCount": 17216, "createdAt": "Sat May 02 11:59:01 +0000 2026", "lang": "en", "bookmarkCount": 25, "isReply": false, "inReplyToId": null, "conversationId": "2050545594867798489", "displayTextRange": [0, 276], "inReplyToUserId": null, "inReplyToUsername": null, "author": {"type": "user", "userName": "esrtweet", "url": "https://x.com/esrtweet", "twitterUrl": "https://twitter.com/esrtweet", "id": "147346374", "name": "Eric S. Raymond", "isVerified": false, "isBlueVerified": true, "verifiedType": null, "profilePicture": "https://pbs.twimg.com/profile_images/925069606/ecsllogo2_normal.png", "coverPicture": "", "description": "", "location": "", "followers": 50834, "following": 219, "status": "", "canDm": false, "canMedi