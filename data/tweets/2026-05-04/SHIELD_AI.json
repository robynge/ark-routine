": {"blocked_by": false, "blocking": false, "followed_by": false, "following": false, "live_following": false, "muting": false}, "rest_id": "10228272", "smart_blocked_by": false, "smart_blocking": false, "super_follow_eligible": false, "super_followed_by": false, "super_following": false, "tweet_counts": {"media_tweets": 16125, "tweets": 61081}, "verification": {"is_blue_verified": true, "verified": false, "verified_type": "Business"}, "website": {"url": "https://t.co/GIOK0JwI68"}}}]}, "place": {}, "entities": {"hashtags": [], "symbols": [], "timestamps": [], "urls": [{"display_url": "youtube.com/watch?v=FOAdh6\u2026", "expanded_url": "https://www.youtube.com/watch?v=FOAdh67NYuU", "indices": [236, 259], "url": "https://t.co/RSdNPEPGAE"}], "user_mentions": []}, "quoted_tweet": null, "retweeted_tweet": null, "isLimitedReply": false, "communityInfo": null, "article": null}, {"type": "tweet", "id": "2051302913272594558", "url": "https://x.com/PepInvestStocks/status/2051302913272594558", "twitterUrl": "https://twitter.com/PepInvestStocks/status/2051302913272594558", "text": "$OUST - Here are 3 strong reasons why these relationships make Ouster an interesting investment:\n\n1. Explosive growth in U.S. defense autonomy\n\nAnduril and Shield AI are two of the fastest-scaling defense tech companies, winning massive contracts (including Anduril\u2019s multi-billion-dollar Army deals for counter-drone and autonomous systems). Both rely on advanced perception for drones, ground vehicles, and AI-driven command platforms. Ouster\u2019s digital LiDAR - Blue UAS-approved and ruggedized - provides the reliable 3D vision these systems need in GPS-denied or contested environments. As these \u201cneo-primes\u201d scale production, Ouster benefits from rising sensor demand.\n\n2. Skydio\u2019s leadership in tactical drones\nSkydio has become the dominant U.S. drone manufacturer, recently securing the largest single-vendor tactical sUAS order in U.S. Army history ($52M+). \n\nIts autonomous drones require precise real-time perception for reconnaissance, base security, and beyond-visual-line-of-sight operations. Ouster\u2019s high-resolution LiDAR complements Skydio\u2019s vision stack, especially in complex or low-visibility conditions, positioning Ouster as a key enabler of America\u2019s push for domestic, secure unmanned systems.\n\n3. Structural tailwinds for Physical AI in national security\n\nAll three companies are at the forefront of AI-powered autonomy, where LiDAR is a critical sensor for safe navigation, object detection, Geopolitical tensions are driving massive investment in resilient, domestically sourced technology. Ouster\u2019s digital LiDAR offers advantages in resolution, power efficiency, and cost - making it a strong fit as these customers move from prototypes to large-scale deployment.", "source": "Twitter for iPhone", "retweetCount": 1, "replyCount": 1, "likeCount": 21, "quoteCount": 0, "viewCount": 1497, "createdAt": "Mon May 04 14:08:20 +0000 2026", "lang": "en", "bookmarkCount": 6, "isReply": false, "inReplyToId": null, "conversationId": "2051302913272594558", "displayTextRange": [0, 267], "inReplyToUserId": null, "inReplyToUsername": null, "author": {"type": "user", "userName": "PepInvestStocks", "url": "https://x.com/PepInvestStocks", "twitterUrl": "https://twitter.com/PepInvestStocks", "id": "1463994727024545796", "name": "Pep Invest", "isVerified": false, "isBlueVerified": true, "verifiedType": null, "profilePicture": "https://pbs.twimg.com/profile_images/2017562600196722688/6atkJ8c-_normal.jpg", "coverPicture": "https://pbs.twimg.com/profile_banners/1463994727024545796/1771161010", "description": "", "location": "Wallstreet ", "followers": 6464, "following": 230, "status": "", "canDm": false, "canMediaTag": true, "createdAt": "Thu Nov 25 22:15:29 +0000 2021", "entities": {"description": {"urls": []}, "url": {}}, "fastFollowersCount": 0, "favouritesCount": 12923, "hasCustomTimelines": true, "isTranslator": false, "medi