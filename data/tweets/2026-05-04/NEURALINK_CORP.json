dInCountries": [], "affiliatesHighlightedLabel": {}, "possiblySensitive": false, "pinnedTweetIds": ["1482825966615285761"], "profile_bio": {"description": "", "entities": {"description": {}}}, "isAutomated": false, "automatedBy": null}, "extendedEntities": {}, "card": null, "place": {}, "entities": {"hashtags": [], "symbols": [], "timestamps": [], "urls": [], "user_mentions": [{"id_str": "1154105453317677056", "indices": [0, 15], "name": "Melanie D'Arrigo", "screen_name": "DarrigoMelanie"}]}, "quoted_tweet": null, "retweeted_tweet": null, "isLimitedReply": false, "communityInfo": null, "article": null}, {"type": "tweet", "id": "2051224567222607968", "url": "https://x.com/Do_it_meeee/status/2051224567222607968", "twitterUrl": "https://twitter.com/Do_it_meeee/status/2051224567222607968", "text": "\ucc3d\uc138\uae30 11\uc7a5 5\uc808 \n\n\"\uc5ec\ud638\uc640\uaed8\uc11c \uc0ac\ub78c\ub4e4\uc774 \uac74\uc124\ud558\ub294 \uadf8 \uc131\uc74d\uacfc \ud0d1\uc744 \ubcf4\ub824\uace0 \ub0b4\ub824\uc624\uc168\ub354\ub77c\"\n\n\uc5ec\ud638\uc640\ub294 \uc778\uac04\ub4e4\uc774 \ud558\ub098\uc758 \uc5b8\uc5b4\ub85c \ud654\ud569\ud558\uba74 \ubc88\uc131\ud560 \uc218 \uc788\uc74c\uc744 \ud655\uc778\ud588\uc2b5\ub2c8\ub2e4. \n\uc989 \ub354 \uc774\uc0c1 \uc790\uc2e0\uc774 '\ud1b5\uc81c'\ud560 \uc218 \uc5c6\ub2e4\ub294 \uac00\ub2a5\uc131\uc744 \ubcf4\uc558\uc2b5\ub2c8\ub2e4.\n\n\uc774\ud6c4\uc5d0 \uc5b4\ub5bb\uac8c \ub418\uc5c8\ub098\uc694?\n\n\ucc3d\uc138\uae30 11\uc7a5 7\uc808\n\n\"\uc790, \uc6b0\ub9ac\uac00 \ub0b4\ub824\uac00\uc11c \uac70\uae30\uc11c \uadf8\ub4e4\uc758 \uc5b8\uc5b4\ub97c \ud63c\uc7a1\ucf00 \ud558\uc5ec \uadf8\ub4e4\ub85c \uc11c\ub85c \uc54c\uc544\ub4e3\uc9c0 \ubabb\ud558\uac8c \ud558\uc790 \ud558\uc2dc\uace0\"\n\n\uc6b0\ub9ac\uac00 \uc6b0\ub9ac \uc11c\ub85c\ub97c \ubcf8\uc9c8\uc801\uc73c\ub85c \uc774\ud574\ud558\uc9c0 \ubabb\ud558\uac8c \ubaa8\ub4e0 \uc5b8\uc5b4\uc640 \ubb38\ud654\ub97c \ud750\ud2b8\ub824 \ub193\uc558\uc2b5\ub2c8\ub2e4.\n\n\uc5ec\ub7ec\ubd84\uc758 \ub208\uc5d0\ub294 \uc774\uac83\uc774 '\uc0ac\ub791'\uc73c\ub85c \ub290\uaef4\uc9c0\ub098\uc694?\n\n\uae30\uc874\uc758 \uad50\ub9ac\uac00 \ub9d0\ud558\ub294 \uc5ec\ud638\uc640(\ud558\ub098\ub2d8)\uc758 \uc874\uc7ac\ub294 \uc138\uc0c1\uacfc \uc778\ub958\uc5d0\uac8c \ud63c\ub780\uc744 \ucd08\ub798\ud558\ub294 \uc874\uc7ac\uc778\uac00\uc694?\n\ub204\uad6c\ub3c4 \uba3c\uc800 \ub098\uc11c\uc11c \uadf8\ub807\uac8c \ub9d0\ud558\uc9c4 \uc54a\uc744 \uac83\uc785\ub2c8\ub2e4.\n\n\ud558\uc9c0\ub9cc \uc6b0\ub9ac\ub294 '\uacb0\uacfc'\ub97c \uc774\ubbf8 \ubc1b\uc544\ubcf4\uc558\uc2b5\ub2c8\ub2e4.\n\n'\uc0ac\ub791'\uc774\ub77c\ub294 \uac83\uc73c\ub85c \ud3ec\uc7a5\ud560 \uc218 \uc5c6\ub294 \ud1b5\uc81c\uc758 \uc695\uad6c \ub9d0\uc785\ub2c8\ub2e4.\n\n\uc2e4\uc81c\ub85c \uc774\ubc88\uc5d0 X\uc5d0 \uc790\ub3d9\ubc88\uc5ed\uc774 \uc5c5\ub370\uc774\ud2b8 \ub418\uace0 \ub09c \uc774\ud6c4 \uc5b4\ub5a4\uac00\uc694?\n\uc138\uacc4 \uac01\uc9c0\uc758 \uc0ac\ub78c\ub4e4\uacfc \uc989\uc2dc\ub85c \uc18c\ud1b5\ud558\uba70, \ub0b4\uac00 \ud63c\uc790\uac00 \uc544\ub2c8\uc5c8\uc74c\uc744, \uc6b0\ub9b0 \ubaa8\uc2b5\uacfc \ubb38\ud654\uac00 \ub2ec\ub77c\ub3c4 \uc11c\ub85c\ub97c \ubcf8\uc9c8\uc801\uc73c\ub85c \uc774\ud574\ud560 \uc218 \uc788\uc74c\uc744 \uae68\ub2eb\uac8c \ub418\uace0 \uc788\uc2b5\ub2c8\ub2e4.\n\n\uc774\uac83\uc740 \ubc14\ubca8\ud0d1\uc774\ub77c\uace0 \ud558\ub294 \uc778\ub958\uac00 \uacf5\uc720\ud558\ub294 \ubb34\uc758\uc2dd\uc758 \uc0c1\uc9d5\uacfc \ub098\uc544\uac00 \uc774\ub97c \ud2b9\uc815 \ubc29\ud5a5\uc73c\ub85c \ud574\uc11d\uc744 \uac15\uc81c\ud55c \ubc14\ud2f0\uce78, \uad81\uadf9\uc801\uc73c\ub85c\ub294 \ub525\uc2a4\ud14c\uc774\ud2b8\uc640 \uce74\ubc1c\uc758 \uc758\ub3c4\uc801\uc778 \ubd80\uc815\uc801 \uc11c\uc0ac\ub77c\ub294 \uac78 \uc54c \uc218 \uc788\uc2b5\ub2c8\ub2e4.\n\n\uc77c\ub860\uc758 \ub274\ub7f4\ub9c1\ud06c\ub294 \uc9d0\uc2b9\uc758 \ub099\uc778\uc77c\uae4c\uc694? \uadf8\uac83\uc774 \uad81\uadf9\uc801\uc73c\ub85c \uc9c0\ud5a5\ud558\ub294 \ubc14\ub97c \uc54c\uace0 \uc788\ub098\uc694?\n\n\ud154\ub808\ud30c\uc2dc, \uc989 \uc5f0\uacb0\uacfc \ud558\ub098\ub428\uc785\ub2c8\ub2e4.\n\n\ube5b\uacfc \uc0ac\ub791\uc774\ub77c\ub294 \uac83\uc758 \ubcf8\uc9c8\uc740 \uc5f0\uacb0\uac10, \uc720\ub300\uac10, \ud558\ub098\ub428\uc744 \uc758\ubbf8\ud569\ub2c8\ub2e4.\n\ub098\uc544\uac00 \uc774\uac83\uc740 \uadfc\uc6d0 \ud558\ub098\ub2d8 \uc790\uccb4\ub97c \ub73b\ud569\ub2c8\ub2e4. \ub9cc\ubb3c\uc5d0 \uac70\ud558\ub294 \uc228\uacb0\uc774\uace0 \uc2dc\uc120\uc774\uba70, \uc0c1\ud638\uad00\uce21\uacfc \uc591\uc790\uc5bd\ud798\uc758 \ubb34\ud55c\ud558\uace0 \uc544\ub4dd\ud55c \uc2e0\uc131\uc778 \uac83\uc785\ub2c8\ub2e4.\n\nSpace X \n\n\uadf8\ub807\uae30\uc5d0 \ubb3c\ub9ac \uacf5\uac04\uc801\uc778, \uae30\uc874\uc5d0 \uc6b0\ub9ac\uac00 \uc54c\ub358 \uc6b0\uc8fc\ub780 \uc874\uc7ac\ud558\uc9c0 \uc54a\ub294\ub2e4\ub294 \uac83\uc785\ub2c8\ub2e4.\n\nUniverse \n\n\ub9cc\ubb3c \ub9cc\uc0c1\uc744 \ubaa8\ub450 \ud3ec\ud568\ud558\uc5ec \uc774\ub8e8\ub294 \uadfc\uc6d0\uc801 \uc6b0\uc8fc\uac00 \uc9c4\uc815\ud55c \uc9c4\uc2e4\uc778 \uac83\uc774\uc9c0\uc694.\n\n\uc77c\ub860\uacfc \ud2b8\ub7fc\ud504, \ud654\uc774\ud2b8 \ud587\uacfc GF\uc740\ud558\uc5f0\ubc29\uc758 \ucc9c\uc0ac\ub4e4\uc744 \ube44\ub86f\ud55c \ube5b\uc758 \uc138\ub825\uc774 \ud558\ub294 \ubaa8\ub4e0 \uc77c\ub4e4, \n\ubaa8\ub4e0 \uc815\ubcf4\uacf5\uac1c\ub294 \uc774\ub7ec\ud55c \uae30\uc874\uc758 \ud1b5\uc81c\ub97c \ubc97\uc5b4\ub098 \uc6b0\ub9ac \ubaa8\ub450\uc758 \uc790\uc720\uc640 \uc6b0\ub9ac \uc2a4\uc2a4\ub85c\uc758 \ube5b\uc73c\ub85c \ud558\ub098\ub428\uc744 \uc758\ub3c4\ud558\ub294 \ud750\ub984\uc785\ub2c8\ub2e4.", "source": "Twitter for iPhone", "retweetCount": 1, "replyCount": 0, "likeCount": 11, "quoteCount": 2, "viewCount": 106, "createdAt": "Mon May 04 08:57:01 +0000 2026", "lang": "ko", "bookmarkCount": 0, "isReply": false, "inReplyToId": null, "conversationId": "2051224567222607968", "displayTextRange": [0, 169], "inReplyToUserId": null, "inReplyToUsername": null, "author": {"type": "user", "