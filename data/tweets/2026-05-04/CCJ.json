 "features": {"large": {"faces": []}, "orig": {"faces": []}}, "id_str": "2051281111896969216", "indices": [183, 206], "media_key": "3_2051281111896969216", "media_results": {"id": "QXBpTWVkaWFSZXN1bHRzOgwAAQoAARx3nU2ZFlAACgACHHedU3aWUTYAAA==", "result": {"__typename": "ApiMedia", "id": "QXBpTWVkaWE6DAABCgABHHedTZkWUAAKAAIcd51TdpZRNgAA", "media_key": "3_2051281111896969216"}}, "media_url_https": "https://pbs.twimg.com/media/HHedTZkWUAAx4Bn.jpg", "original_info": {"focus_rects": [{"h": 722, "w": 1290, "x": 0, "y": 0}, {"h": 1074, "w": 1074, "x": 216, "y": 0}, {"h": 1074, "w": 942, "x": 335, "y": 0}, {"h": 1074, "w": 537, "x": 538, "y": 0}, {"h": 1074, "w": 1290, "x": 0, "y": 0}], "height": 1074, "width": 1290}, "sizes": {"large": {"h": 1074, "w": 1290}}, "type": "photo", "url": "https://t.co/FObUuUo6fL"}]}, "card": null, "place": {}, "entities": {"hashtags": [], "symbols": [{"indices": [164, 168], "text": "CCJ"}], "timestamps": [], "urls": [], "user_mentions": [{"id_str": "1715083902153379840", "indices": [169, 182], "name": "The Nuclear Company", "screen_name": "TheNuclearCo"}]}, "quoted_tweet": {"type": "tweet", "id": "2051278792522363053", "url": "https://x.com/energybants/status/2051278792522363053", "twitterUrl": "https://twitter.com/energybants/status/2051278792522363053", "text": "Breaking: Brookfield and The Nuclear Company teaming up to deliver GW-scale nuclear\n\nProud to announcing a joint venture between The Nuclear Company and Brookfield to deliver Westinghouse reactors, including to manage the completion of AP1000s in South Carolina.\n\nFrom the day I discovered nuclear energy my goal has been to build as much of it as possible for the world. Today, with my team at @thenuclearco, we're taking a huge step towards that. It's been an honor to work as Chief of Staff for proven builder-CEO @JonathanWebbKY alongside our legendary Chief Nuclear Officer @TheNuclearJoe as we build the team and technology that can finally fix the nuclear plant deployment problem in the West.\n\nI've been an advocate for nuclear energy long enough to see the revolution in public appreciation for this wondrous technology, but just being popular isn't enough. We have to be able to build on-time, on-budget, with proven designs that are repeated over and over with an experienced and disciplined project management team using the best emerging tech.\n\nThat is precisely what we're doing at The Nuclear Company. I'll be sharing more going forward as we deliver on the awesome potential unlocked by today's announcement.", "source": "Twitter for iPhone", "retweetCount": 30, "replyCount": 19, "likeCount": 151, "quoteCount": 9, "viewCount": 13338, "createdAt": "Mon May 04 12:32:29 +0000 2026", "lang": "en", "bookmarkCount": 13, "isReply": false, "inReplyToId": null, "conversationId": "2051278792522363053", "displayTextRange": [0, 278], "inReplyToUserId": null, "inReplyToUsername": null, "author": {"type": "user", "userName": "energybants", "url": "https://x.com/energybants", "twitterUrl": "https://twitter.com/energybants", "id": "3337913081", "name": "Mark Nelson", "isVerified": false, "isBlueVerified": true, "verifiedType": null, "profilePicture": "https://pbs.twimg.com/profile_images/1975574782054633472/GHPuGLPm_normal.jpg", "coverPicture": "https://pbs.twimg.com/profile_banners/3337913081/1477367915", "description": "", "location": "Chicago, IL", "followers": 86548, "following": 2040, "status": "", "canDm": true, "canMediaTag": true, "createdAt": "Sat Jun 20 23:41:47 +0000 2015", "entities": {"description": {"urls": []}, "url": {}}, "fastFollowersCount": 0, "favouritesCount": 19635, "hasCustomTimelines": true, "isTranslator": false, "mediaCount": 1029, "statusesCount": 5939, "withheldInCountries": [], "affiliatesHighlightedLabel": {}, "possiblySensitive": false, "pinnedTweetIds": ["2010520488808693928"], "profile_bio": {"description": "Building nuclear. Chief of Staff @TheNuclearCo. Prev: @RadiantEnergyG @envprogress @cambridge_eng @run4okstate", "enti