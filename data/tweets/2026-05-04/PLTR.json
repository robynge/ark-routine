ensitive": false, "pinnedTweetIds": ["1867747081655558162"], "profile_bio": {"description": "$PLTR", "entities": {"description": {"symbols": [{"indices": [0, 5], "text": "PLTR"}]}, "url": {"urls": [{"display_url": "pltrdog.com", "expanded_url": "https://www.pltrdog.com", "indices": [0, 23], "url": "https://t.co/tmzTPmRfmF"}]}}}, "isAutomated": false, "automatedBy": null}, "extendedEntities": {"media": [{"allow_download_status": {"allow_download": true}, "display_url": "pic.twitter.com/RcXaiDXhhs", "expanded_url": "https://twitter.com/PLTR_Dog/status/2051138001393287450/photo/1", "ext_media_availability": {"status": "Available"}, "features": {"large": {"faces": []}, "orig": {"faces": []}}, "id_str": "2051137995303211009", "indices": [60, 83], "media_key": "3_2051137995303211009", "media_results": {"id": "QXBpTWVkaWFSZXN1bHRzOgwAAQoAARx3GyOrWtABCgACHHcbJRZaARoAAA==", "result": {"__typename": "ApiMedia", "id": "QXBpTWVkaWE6DAABCgABHHcbI6ta0AEKAAIcdxslFloBGgAA", "media_key": "3_2051137995303211009"}}, "media_url_https": "https://pbs.twimg.com/media/HHcbI6ta0AEeDx6.jpg", "original_info": {"focus_rects": [{"h": 660, "w": 1179, "x": 0, "y": 111}, {"h": 1179, "w": 1179, "x": 0, "y": 0}, {"h": 1344, "w": 1179, "x": 0, "y": 0}, {"h": 1961, "w": 981, "x": 0, "y": 0}, {"h": 1961, "w": 1179, "x": 0, "y": 0}], "height": 1961, "width": 1179}, "sizes": {"large": {"h": 1961, "w": 1179}}, "type": "photo", "url": "https://t.co/RcXaiDXhhs"}]}, "card": null, "place": {}, "entities": {"hashtags": [{"indices": [37, 46], "text": "palantir"}, {"indices": [47, 54], "text": "\u30d1\u30e9\u30f3\u30c6\u30a3\u30a2"}, {"indices": [55, 59], "text": "\u7c73\u56fd\u682a"}], "symbols": [{"indices": [31, 36], "text": "PLTR"}], "timestamps": [], "urls": [], "user_mentions": []}, "quoted_tweet": null, "retweeted_tweet": null, "isLimitedReply": false, "communityInfo": null, "article": null}, {"type": "tweet", "id": "2051163442220867763", "url": "https://x.com/PalantirOg/status/2051163442220867763", "twitterUrl": "https://twitter.com/PalantirOg/status/2051163442220867763", "text": "$PLTR \u2018Twas The Night Before Earnings ~ A Palantir Tale \ud83d\udd6f\ufe0f\ud83d\udd2e\n\n\u2019Twas the night before earnings, when all through the Street,\u2028Not a trader was stirring, not even a tweet.\u2028The faithful shareholders rested, their PLTR held tight,\u2028While nervous bears grumbled through another sleepless night.\nTheir portfolios bulged with conviction and care,\u2028In hopes that big beats soon would be there.\u2028The long-term believers lay snug in their beds,\u2028While visions of vindication danced in their heads.\nWhen out on the wire there arose such a clatter,\u2028We sprang to the earnings call to see what was the matter.\u2028Away to the screens we flew like a flash,\u2028Tore open the charts and threw up the cash.\nThe moon on the breast of the new-risen chart\u2028Gave the luster of green to the bulls\u2019 upward start,\u2028When, what to our wondering eyes should appear,\u2028But a sleigh full of metrics with a driver so dear.\nWith an energetic figure, so quick and so sharp,\u2028We knew in a moment it must be St. Karp!\u2028More rapid than eagles his numbers they came,\u2028And he whistled, and shouted, and called them by name:\n\u201cRevenue surging! Commercial growth vast!\u2028AIP leading the way, margins holding fast!\u2028To the top of the Street! To the moon for the bulls!\u2028Now dash away, bears! Dash away, doubters and shorts!\u201d\nAs dry leaves that before the wild hurricane fly,\u2028When they meet with strong earnings, mount straight to the sky,\u2028So up to fresh highs the green candles they flew,\u2028With the sleigh full of contracts and new prospects too.\nAnd then, in a twinkling, we heard on the call\u2028The prancing and pawing of metrics standing tall.\u2028As we drew in our heads and were turning around,\u2028Down the screen came the report with a bound.\nHe was dressed in a white T-shirt so crisp and so bright,\u2028With that signature orange watch keeping time through the night.\u2028His famous hair perfectly tousled and grand,\u2028The cross-country skier\u2019s physique and endurance at hand.\nA bundle of deals he had flung on his back,\u2028Massive new commercial wins leading the pack,\u2028Record government contracts that set the bar higher,\u2028Bringing fresh customer wins and bigger deals on fire.\nHe paced with that trademark assurance and grace,\u2028Full of opportunities galore on Earth and in space.\u2028His eyes\u2014how they sparkled! His focus\u2014how keen!\u2028His words crisp and sincere in a sharp, steady stream.\nHe spoke not of hype but of serious endeavor,\u2028\u201cCustomers with real problems,\u201d he said, calm as ever.\u2028\u201cInexplicable revenue from trust deeply earned\u201d\u2014\u2028The bears quoted him often, but now they were burned.\nThen Shyam stepped up in his lavender grace,\u2028\u201cOntology powers the AIP\u2014LLMs and workflows, side by side.\u2028Re-platforming customers leapfrog the pack,\u2028AI FDE turns years of work into weeks\u2014imagine that!\u201d\nFor years the bears mocked: \u201cNo commercial scale here!\u2028Valuation insane! Profits disappear!\u201d\u2028Yet the trends now prove it\u2014U.S. comm surging strong,\u2028With record TCV bookings singing the bears\u2019 swan song.\nSt. Karp eyed the shorts with a serious spark,\u2028\u201cThis behavior is egregious \u2014 I\u2019ll be dancing when proven wrong!\u201d\u2028\u201cShorting chips and ontology? Batshit crazy!\u201d he declared.\u2028\u201cWe\u2019re crushing it \u2014 we will be the most important software company in the world!\u201d\nWith Dan Ives and Mariana Perez on the call,\u2028Oppenheimer at two-hundred, Citi at two-thirty-five, the Street sees it all.\u2028Positive momentum, revisions galore,\u2028The analysts finally knocking down Wall Street\u2019s door.\nHe spoke not a word more, but went straight to his work,\u2028And thanked his team of Palantirians and loyal retail HODLers; then turned with a jerk.\u2028And addressing the watchers with a \u2018til next quarter gleam in his eye,\u2028Gave a nod as the earnings call drew to a close.\nAway to his sleigh, to his team gave a whistle,\u2028And away they all flew like a Maven-guided missile.\u2028But we heard him exclaim, ere he drove out of sight,\u2028\u201cHappy earnings to all\u2014and to bears\u2026 read \u2018em and weep tonight!\u201d", "source": "Twitter for iPhone", "retweetCount": 1, "replyCount": 1, "likeCount": 21, "quoteCount": 0, "viewCount": 677, "createdAt": "Mon May 04 04:54:08 +0000 2026", "lang": "en", "bookmarkCount": 0, "isReply": false, "inReplyToId": null, "conversationId": "2051163442220867763", "displayTextRange": [0, 269], "inReplyToUserId": null, "inReplyToUsername": null, "author": {"type": "user", "userName": "PalantirOg", "url": "https://x.com/PalantirOg", "twitterUrl": "https://twitter.com/PalantirOg", "id": "1845587767889129472", "name": "Palantir OG", "isVerified": false, "isBlueVerified": true, "verifiedType": null, "profilePicture": "https://pbs.twimg.com/profile_images/2050285864614301696/S04qqF6c_normal.jpg", "coverPicture": "https://pbs.twimg.com/profile_banners/1845587767889129472/1777685590", "description": "", "location": "", "followers": 2749, "following": 566, "status": "", "canDm": true, "canMediaTag": true, "createdAt": "Sun Oct 13 22:10:03 +0000 2024", "entities": {"description": {"urls": []}, "url": {}}, "fastFollowersCount": 0, "favouritesCount": 61161, "hasCustomTimelines": true, "isTranslator": false, "mediaCount": 1071, "statusesCount": 5611, "withheldInCountries": [], "affiliatesHighlightedLabel": {}, "possiblySensitive": false, "pinnedTweetIds": ["1855273998764200124"], "profile_bio": {"description": "Here to thank and support the great visionaries and true patriots of our time who lead, build and fund the world's most innovative companies. PLTR since DPO.", "entities": {"description": {}}}, "isAutomated": false, "