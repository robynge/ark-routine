2051249902957522945/vid/avc1/640x360/QxSWl-ocjzgB_ggX.mp4?tag=27"}, {"bitrate": 2176000, "content_type": "video/mp4", "url": "https://video.twimg.com/amplify_video/2051249902957522945/vid/avc1/1280x720/qBFCoxe5uEkcrvev.mp4?tag=27"}, {"bitrate": 10368000, "content_type": "video/mp4", "url": "https://video.twimg.com/amplify_video/2051249902957522945/vid/avc1/1920x1080/gpAh419nFbcAvBk0.mp4?tag=27"}]}}]}, "card": null, "place": {}, "entities": {"hashtags": [], "symbols": [], "timestamps": [], "urls": [], "user_mentions": []}, "quoted_tweet": null, "retweeted_tweet": null, "isLimitedReply": false, "communityInfo": null, "article": null}, {"type": "tweet", "id": "2051263838016667766", "url": "https://x.com/UKikaski/status/2051263838016667766", "twitterUrl": "https://twitter.com/UKikaski/status/2051263838016667766", "text": "\ud83c\uddfa\ud83c\udde6 \ud835\udde0\ud835\uddd4\ud835\uddec \ud835\udff5 | \ud835\udded\ud835\uddd8\ud835\udddf\ud835\uddd8\ud835\udde1\ud835\udde6\ud835\uddde\ud835\uddec | \ud835\udde9\ud835\udddc\ud835\uddd6\ud835\udde7\ud835\udde2\ud835\udde5\ud835\uddec \ud835\uddd7\ud835\uddd4\ud835\uddec\n\nSpeaking at the European Political Community summit in Yerevan today, Zelensky stated that Russia announced a Victory Day parade without military equipment because they cannot afford to use it and are afraid drones will buzz over Red Square.\n\nHe did not rule it out.\n\nThe security threat seems real and Russia's international allies took note.\n\nThe guest list is telling.\n\nConfirmed attendees:\n\n\u2022 Alexander Lukashenko, President of Belarus\n\u2022 Kassym-Jomart Tokayev, President of Kazakhstan\n\u2022 Sadyr Japarov, President of Kyrgyzstan\n\u2022 Robert Fico, Prime Minister of Slovakia\n\n(Ed.; What Ramzan Kadyrov\ud83e\uddbc doing?)\n\nNotable absences: Xi Jinping, Lula, and every world leader who made last year's parade a Kremlin legitimacy showcase. \n\nRussia has not displayed military hardware at a May 9 parade since 2008. The Kremlin cited the \"current operational situation.\" \n\nNo State Duma deputies received invitations this year.\n\nRussian military blogger Alexander Kots wrote the parade was nearly canceled entirely due to the drone threat.\n\nPeskov called it a response to Ukrainian \"terrorist activity.\" \n\n(Ed.; True. If Russia stopped terrorizing Ukraine, they could have a May 9 parade in peace.)\n\nSource: TG Zelensky | TG Alexander Kots\n\n#OSINT #Ukraine", "source": "Twitter for iPhone", "retweetCount": 1, "replyCount": 2, "likeCount": 11, "quoteCount": 0, "viewCount": 1296, "createdAt": "Mon May 04 11:33:04 +0000 2026", "lang": "en", "bookmarkCount": 0, "isReply": false, "inReplyToId": null, "conversationId": "2051263838016667766", "displayTextRange": [0, 254], "inReplyToUserId": null, "inReplyToUsername": null, "author": {"type": "user", "userName": "UKikaski", "url": "https://x.com/UKikaski", "twitterUrl": "https://twitter.com/UKikaski", "id": "1197480887430078464", "name": "OSINT Intuit\u2122", "isVerified": false, "isBlueVerified": true, "verifiedType": null, "profilePicture": "https://pbs.twimg.com/profile_images/1980381356514254848/ffjt_wSs_normal.jpg", "coverPicture": "https://pbs.twimg.com/profile_banners/1197480887430078464/1761573819", "description": "", "location": "USA", "followers": 70820, "following": 2490, "status": "", "canDm": true, "canMediaTag": true, "createdAt": "Thu Nov 21 11:44:36 +0000 2019", "entities": {"description": {"urls": []}, "url": {}}, "fastFollowersCount": 0, "favouritesCount": 7940, "hasCustomTimelines": true, "isTranslator": false, "mediaCount": 22350, "statusesCount": 40012, "withheldInCountries": [], "affiliatesHighlightedLabel": {}, "possiblySensitive": false, "pinnedTweetIds": [], "profile_bio": {"description": "Clinical, unsparing, quietly damning OSINT analysis of geopolitical events. Providing timely context before the narrative war begins. NAFO OG 2022.", "entities": {"description": {}}}, "isAutomated": false, "automatedBy": null}, "extend