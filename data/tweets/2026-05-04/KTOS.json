x": 832, "y": 0}, {"h": 992, "w": 1600, "x": 0, "y": 0}], "height": 992, "width": 1600}, "sizes": {"large": {"h": 992, "w": 1600}}, "type": "photo", "url": "https://t.co/vy1KXstaIN"}]}, "card": null, "place": {}, "entities": {"hashtags": [], "symbols": [{"indices": [199, 203], "text": "TEM"}, {"indices": [205, 210], "text": "ALAB"}, {"indices": [212, 216], "text": "LEU"}, {"indices": [218, 223], "text": "AXON"}, {"indices": [225, 230], "text": "KTOS"}, {"indices": [232, 237], "text": "RKLB"}, {"indices": [239, 244], "text": "IREN"}, {"indices": [246, 250], "text": "NET"}, {"indices": [252, 257], "text": "SYNA"}, {"indices": [259, 264], "text": "INDI"}], "timestamps": [], "urls": [], "user_mentions": []}, "quoted_tweet": null, "retweeted_tweet": null, "isLimitedReply": false, "communityInfo": null, "article": null}}, {"reason": "cashtags=6", "tweet": {"type": "tweet", "id": "2051301067694989786", "url": "https://x.com/WallStDiaries/status/2051301067694989786", "twitterUrl": "https://twitter.com/WallStDiaries/status/2051301067694989786", "text": "$AVAV $KTOS $ONDS\nDrone sava\u015flar\u0131: Modern cephenin yeni hakimi ve yat\u0131r\u0131m\u0131n asimetrik g\u00fcc\u00fc\n\nModern sava\u015f\u0131n matemati\u011fi geri d\u00f6n\u00fclemez bir \u015fekilde de\u011fi\u015fti: Bug\u00fcn 500 dolarl\u0131k bir FPV drone, 5 milyon dolarl\u0131k bir ana muharebe tank\u0131n\u0131 oyun d\u0131\u015f\u0131 b\u0131rakabiliyor. \u0130kinci D\u00fcnya Sava\u015f\u0131'nda \"Blitzkrieg\" doktrini neyse, bug\u00fcn Ukrayna ve Orta Do\u011fu koridorlar\u0131nda izledi\u011fimiz \"Drone Swarms\" ve \"Loitering Munition\" sald\u0131r\u0131lar\u0131 ayn\u0131 y\u0131k\u0131c\u0131 etkiyi yarat\u0131yor. Peki, bu teknolojik k\u0131r\u0131lmada hangi \u015firketler savunma sanayii portf\u00f6ylerini domine edecek?\n\n$AVAV (AeroVironment), loitering munition segmentinin tart\u0131\u015fmas\u0131z lideri. Switchblade serisiyle \"kamikaze drone\" kavram\u0131n\u0131 sava\u015f sahas\u0131nda standart haline getirdiler. AVAV'\u0131n as\u0131l g\u00fcc\u00fc, sadece donan\u0131m satmas\u0131 de\u011fil; Pentagon'un \"Replicator\" program\u0131 gibi devasa ihalelerde \"battle-tested\" (muharebe onayl\u0131) tek \u00e7\u00f6z\u00fcm orta\u011f\u0131 olarak \u00f6ne \u00e7\u0131kmas\u0131. \u015eirketin backlog verileri, sipari\u015flerin sadece ABD ile s\u0131n\u0131rl\u0131 kalmad\u0131\u011f\u0131n\u0131, m\u00fcttefik \u00fclkelerin de h\u0131zla bu d\u00fc\u015f\u00fck maliyetli ama y\u00fcksek hassasiyetli sisteme ge\u00e7ti\u011fini g\u00f6steriyor.\n\n$KTOS (Kratos) ise madalyonun di\u011fer y\u00fcz\u00fcn\u00fc, yani \"Attritable\" (feda edilebilir) jet teknolojisini temsil ediyor. Kratos, F-35 gibi 100 milyon dolarl\u0131k u\u00e7aklar\u0131n yan\u0131na \"Loyal Wingman\" olarak entegre edilebilen otonom jetler \u00fcretiyor. Hava kuvvetlerinin pilot kayb\u0131n\u0131 minimize etme ve maliyeti d\u00fc\u015f\u00fcrme bask\u0131s\u0131, KTOS'un otonom u\u00e7u\u015f yaz\u0131l\u0131mlar\u0131n\u0131 paha bi\u00e7ilemez k\u0131l\u0131yor. Bu, sadece bir drone sat\u0131\u015f\u0131 de\u011fil; hava sava\u015f\u0131n\u0131n t\u00fcm operasyonel maliyet yap\u0131s\u0131n\u0131 de\u011fi\u015ftiren bir hamle.\n\n$ONDS (Ondas Holdings) cephesinde ise hikaye daha \u00e7ok \"altyap\u0131 ve zeka\" \u00fczerine kurulu. \u00d6zellikle \"Drone-in-a-Box\" \u00e7\u00f6z\u00fcmleriyle otonom devriye ve Edge Computing yeteneklerini birle\u015ftiriyorlar. Sava\u015f\u0131n sadece m\u00fchimmattan ibaret olmad\u0131\u011f\u0131n\u0131, s\u00fcrd\u00fcr\u00fclebilir Intelligence ve lojistik a\u011f\u0131n\u0131n kritik oldu\u011funu bilen yat\u0131r\u0131mc\u0131lar i\u00e7in ONDS, bu ekosistemin g\u00f6r\u00fcnmez ama hayati \"sinir sistemi\" rol\u00fcn\u00fc \u00fcstleniyor.\n\n\u0130kinci derece etkiyi \u0131skalamay\u0131n: Bu yar\u0131\u015f\u0131n as\u0131l kazanan\u0131 sadece drone \u00fcreticileri olmayacak. Drone yo\u011funlu\u011fu artt\u0131k\u00e7a, bu sistemleri k\u00f6reltecek Electronic Warfare (EW) ve kar\u015f\u0131 drone (C-UAS) teknolojilerine olan talep katlanarak b\u00fcy\u00fcyecek. Ayr\u0131ca, \"Attrition Warfare\" (y\u0131pratma sava\u015f\u0131) d\u00f6neminde m\u00fchimmat \u00fcretim h\u0131z\u0131, teknolojik \u00fcst\u00fcnl\u00fc\u011f\u00fcn \u00f6n\u00fcne ge\u00e7ebilir. Yat\u0131r\u0131mc\u0131lar i\u00e7in as\u0131l soru \u015fu: Hangi \u015firket, tedarik zincirini en h\u0131zl\u0131 \u00f6l\u00e7eklendirip \"maliyet/\u00f6ld\u00fcr\u00fcc\u00fcl\u00fck\" oran\u0131nda rakiplerine fark atacak?\n\nKaynak: InvestorPlace", "source": "Twitter for iPhone", "retweetCount": 0, "replyCount": 1, "likeCount": 28, "quoteCount": 0, "viewCount": 2130, "createdAt": "Mon May 04 14:01:00 +0000 2026", "lang": "tr", "bookmarkCount": 5, "isReply": false, "inReplyToId": null, "conversationId": "2051301067694989786", "displayTextRange": [0, 279], "inReplyToUserId": null, "inReplyToUsername": null, "author": {"type": "user", "userName": "WallStDiaries", "url": "https://x.com/WallStDiaries", "twitterUrl": "https://twitter.com/WallStDiaries", "id": "1856355605960654848", "name": "Wall Street G\u00fcnl\u00fckleri", "isVerified": false, "isBlueVerified": true, "verifiedType": null, "profilePicture": "https://pbs.twimg.com/profile_images/1992607305070759936/TxOzCOgu_normal.jpg", "coverPicture": "https://pbs.twimg.com/profile_banners/1856355605960654848/1763910045", "description": "", "location": "", "followers": 27046, "following": 547, "status": "", "canDm": true, "canMediaTag": false, "createdAt": "Tue Nov 12 15:17:36 +0000 2024", "entities": {"description": {"urls": []}, "url": {}}, "fastFollowersCount": 0, "favouritesCount": 22304, "hasCustomTimelines": true, "isTranslator": false, "mediaCount": 11491, "statusesCount": 24562, "withheldInCountries": [], "affiliatesHighlightedLabel": {}, "possiblySensitive": false, "pinnedTweetIds": [], "profile_bio": {"description": "ABD Borsalar\u0131ndaki \u015firketlerden e