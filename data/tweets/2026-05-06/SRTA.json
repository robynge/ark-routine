": {"name": "production"}, "device": {"name": "iPhone", "version": "13"}}}, "name": "summary_large_image", "url": "https://t.co/VFtzK2OrsC", "user_refs_results": []}, "place": {}, "entities": {"hashtags": [], "symbols": [{"indices": [0, 5], "text": "SRTA"}], "urls": [{"display_url": "ir.stratacritical.com/news-events/pr\u2026", "expanded_url": "https://ir.stratacritical.com/news-events/press-releases/detail/140/strata-critical-medical-announces-first-quarter-2026-results", "indices": [778, 801], "url": "https://t.co/VFtzK2OrsC"}], "user_mentions": []}, "quoted_tweet": null, "retweeted_tweet": null, "isLimitedReply": false, "communityInfo": null, "article": null}, {"type": "tweet", "id": "2051981844653174805", "url": "https://x.com/wallstengine/status/2051981844653174805", "twitterUrl": "https://twitter.com/wallstengine/status/2051981844653174805", "text": "$SRTA Q1\u201926 EARNINGS HIGHLIGHTS\n\n\ud83d\udd39 Revenue: $67.4M (Est. $63.68M) \ud83d\udfe2; +87.4% YoY\n\ud83d\udd39 EPS: $0.03 (Est. $(0.03)) \ud83d\udfe2\n\ud83d\udd39 Logistics Revenue: $47.6M; +32.4% YoY\n\ud83d\udd39 Clinical Revenue: $19.8M; +12.7% QoQ\n\ud83d\udd39 Adjusted EBITDA: $6.4M\n\nFY 2026 Guide:\n\ud83d\udd39 Revenue: $260M-$275M (Est. $269.1M) \ud83d\udfe1\n\ud83d\udd39 Adjusted EBITDA: $29M-$33M\n\ud83d\udd39 Free Cash Flow Before Aircraft & Engine Acquisitions: $15M-$22M\n\nSegment Performance:\n\ud83d\udd39 Logistics Gross Profit: $9.2M; +29.9% YoY\n\ud83d\udd39 Logistics Gross Margin: 19.3%\n\ud83d\udd39 Clinical Gross Profit: $5.0M; +29.2% QoQ\n\ud83d\udd39 Clinical Gross Margin: 25.0%\n\nOther Metrics:\n\ud83d\udd39 Gross Profit: $14.1M; +100.2% YoY\n\ud83d\udd39 Gross Margin: 21.0%; +140 bps YoY\n\ud83d\udd39 Operating Cash Flow: $3.9M\n\ud83d\udd39 Free Cash Flow Before Aircraft & Engine Acquisitions: $2.1M\n\ud83d\udd39 Cash & Short-Term Investments: $58.8M\n\ud83d\udd39 Ohio Valley Perfusion Associates: Acquired for approximately $1M\n\ud83d\udd39 Fleet: Approximately 35 aircraft, including 10 owned aircraft\n\ud83d\udd39 Organ Recovery Hubs: 13\n\nFinancials:\n\ud83d\udd39 Net Income From Continuing Operations: $2.4M\n\ud83d\udd39 Operating Loss From Continuing Operations: $(3.0)M\n\ud83d\udd39 Adjusted SG&A: $9.2M\n\nCommentary:\n\ud83d\udd38 \u201cWe are pleased to report Q1 results that came in ahead of our expectations, reflecting both strong execution on our growth plan and improving industry dynamics.\u201d\n\n\ud83d\udd38 \u201cThe underlying strength of our transformed economic model is finally shining through as we began generating operating cash flow this quarter.\u201d\n\n\ud83d\udd38 \u201cOur Clinical division showed especially strong sequential growth, with Gross Profit up nearly 30% versus Q4 2025, driven by a combination of new customer wins, a rebound in overall industry organ donors and continued industry mix shift towards third-party surgical recovery and NRP, where Strata is a market leader.\u201d", "source": "Twitter for iPhone", "retweetCount": 4, "replyCount": 1, "likeCount": 19, "quoteCount": 0, "viewCount": 7081, "createdAt": "Wed May 06 11:06:10 +0000 2026", "lang": "en", "bookmarkCount": 0, "isReply": false, "inReplyToId": null, "conversationId": "2051981844653174805", "displayTextRange": [0, 269], "inReplyToUserId": null, "inReplyToUsername": null, "author": {"type": "user", "userName": "wallstengine", "url": "https://x.com/wallstengine", "twitterUrl": "https://twitter.com/wallstengine", "id": "1508426880860704771", "name": "Wall St Engine", "isVerified": false, "isBlueVerified": true, "verifiedType": null, "profilePicture": "https://pbs.twimg.com/profile_images/1691846947857178624/oZp5wB4r_normal.jpg", "coverPicture": "https://pbs.twimg.com/profile_banners/1508426880860704771/1693301985", "description": "", "location": "Wall Street", "followers": 144944, "following": 774, "status": "", "canDm": true, "canMediaTag": true, "createdAt": "Mon Mar 28 12:53:25 +0000 2022", "entities": {"description": {"urls": []}, "ur