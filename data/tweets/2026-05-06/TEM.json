s/2052025627533049915/photo/1", "ext_media_availability": {"status": "Available"}, "features": {"large": {"faces": []}, "orig": {"faces": []}}, "id_str": "2052025620662730752", "indices": [47, 70], "media_key": "3_2052025620662730752", "media_results": {"id": "QXBpTWVkaWFSZXN1bHRzOgwAAQoAARx6Qm4NmkAACgACHHpCb6cbADsAAA==", "result": {"__typename": "ApiMedia", "id": "QXBpTWVkaWE6DAABCgABHHpCbg2aQAAKAAIcekJvpxsAOwAA", "media_key": "3_2052025620662730752"}}, "media_url_https": "https://pbs.twimg.com/media/HHpCbg2aQAAf24t.jpg", "original_info": {"focus_rects": [{"h": 675, "w": 1206, "x": 0, "y": 0}, {"h": 1206, "w": 1206, "x": 0, "y": 0}, {"h": 1375, "w": 1206, "x": 0, "y": 0}, {"h": 2412, "w": 1206, "x": 0, "y": 0}, {"h": 2622, "w": 1206, "x": 0, "y": 0}], "height": 2622, "width": 1206}, "sizes": {"large": {"h": 2048, "w": 942}}, "type": "photo", "url": "https://t.co/JaihvZxLSn"}]}, "card": null, "place": {}, "entities": {"hashtags": [], "symbols": [{"indices": [12, 16], "text": "tem"}], "timestamps": [], "urls": [], "user_mentions": []}, "quoted_tweet": null, "retweeted_tweet": null, "isLimitedReply": false, "communityInfo": null, "article": null}, {"type": "tweet", "id": "2052009244962984408", "url": "https://x.com/AuditTheHerd/status/2052009244962984408", "twitterUrl": "https://twitter.com/AuditTheHerd/status/2052009244962984408", "text": "$TEM I\u2019ve largely stopped trying to make sense of short term price swings around earnings, but if I had to interpret the ER reaction, it likely stems from the headline GAAP net loss figure. If you want to focus on the actual business, look at the gross profit growth. That is the true picture. \n\nAnyways, I'll give more context on the net loss figure. \n\nThe reported net loss was $125.9 million for the quarter. That figure includes $56.3 million of stock based compensation expense and related employer payroll taxes, as well as $32.3 million in unrealized losses on marketable securities.\n\nIf we adjust for the payroll tax component and the mark to market losses on securities \u2014 both of which I view as largely non recurring or timing related and further consider non cash items such as depreciation and amortization, we arrive at an adjusted non GAAP loss of approximately $22 million.\n\nWhile adding back depreciation and amortization is debatable depending on the capital intensity of the business, the payroll tax and unrealized securities impacts are, in my view, one off in nature and should normalize over the remainder of the year. On that basis, the underlying operating performance appears less severe than the GAAP headline suggests. \n\nTempus is close to an inflection point in their business. Its ironic that the market is shrugging this off.  It will become evident the next year or so.", "source": "Twitter for iPhone", "retweetCount": 2, "replyCount": 3, "likeCount": 31, "quoteCount": 1, "viewCount": 1624, "createdAt": "Wed May 06 12:55:03 +0000 2026", "lang": "en", "bookmarkCount": 2, "isReply": false, "inReplyToId": null, "conversationId": "2052009244962984408", "displayTextRange": [0, 279], "inReplyToUserId": null, "inReplyToUsername": null, "author": {"type": "user", "userName": "AuditTheHerd", "url": "https://x.com/AuditTheHerd", "twitterUrl": "https://twitter.com/AuditTheHerd", "id": "2001724228165603331", "name": "Audit The Herd", "isVerified": false, "isBlueVerified": true, "verifiedType": null, "profilePicture": "https://pbs.twimg.com/profile_images/2009656638802673664/r8l42ol-_normal.jpg", "coverPicture": "https://pbs.twimg.com/profile_banners/2001724228165603331/1768601479", "description": "", "location": "", "followers": 3486, "following": 61, "status": "", "canDm": true, "canMediaTag": true, "createdAt": "Thu Dec 18 18:40:28 +0000 2025", "entities": {"description": {"urls": []}, "url": {}}, "fastFollowersCount": 0, "favouritesCount": 4627, "hasCustomTimelines": true, "isTranslator": false, "mediaCount": 153, "statusesCount": 1504, "withheldInCountries": [], "affiliate